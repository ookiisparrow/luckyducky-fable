{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
