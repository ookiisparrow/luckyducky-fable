@import './styles/tokens.wxss';

page {
  background: var(--ld-bg);
  color: var(--ld-ink);
  font-size: 28rpx;
  font-family: var(--ld-font-brand); /* 品牌字体全局应用（战役 flag·主脑拍板）——见 tokens.wxss 注释 */
  font-weight: 500; /* 只注册了 500/700 两档字重（brandFont.ts BRAND_FONTS），不钉此值会落到默认 400——
    CSS 字重匹配会就近吃 500 那档渲染（而非回退栈下一个字体族），全站正文视觉变粗且不可预期；
    显式钉 500 使其命中已注册字重、行为确定（P2 review 修复·mp-7fixes 批4附） */
  -webkit-font-smoothing: antialiased;
}

/* 骨架屏微光（home/catalog 共用·加载态设计对齐 Claude Design 通过稿）：配 background-size:200% 的
   渐变骨架从右向左扫过一道亮带。全局 keyframe（app.wxss 作用域全局），各页骨架 class 引用即可。 */
@keyframes ld-shimmer {
  0% {
    background-position: 150% 0;
  }
  100% {
    background-position: -150% 0;
  }
}
