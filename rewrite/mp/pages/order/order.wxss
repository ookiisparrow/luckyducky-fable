/* 订单详情·重设计对齐 Checkout.jsx 的 OrderStatus 版式。设计 402px 画板→rpx（×1.87）。
   页浅灰底、白卡圆角+浅影分隔；co- 前缀沿设计（与 checkout 同词汇·本页自包含）；
   coord- 为订单态专属件（状态横幅/物流/申请售后/去评价）。token 见 styles/tokens.wxss。 */
.co {
  min-height: 100vh;
  background: #f4f4f5; /* 设计 co 页底浅灰·tokens 无对应中性灰 */
  color: var(--ld-content);
}
.co image {
  display: block;
}
.co-ico {
  width: 34rpx;
  height: 34rpx;
}
.co-ico-lg {
  width: 44rpx;
  height: 44rpx;
}

/* ---------- 内容容器 ---------- */
.co-body {
  padding: 22rpx 26rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* ---------- 状态横幅（订单态签名件） ---------- */
.coord-banner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: var(--ld-radius-md);
  padding: 34rpx 30rpx;
}
.coord-lilac {
  background: var(--ld-bg-lilac);
  border: 1rpx solid var(--ld-purple-line);
}
.coord-sage {
  background: var(--ld-bg-sage);
  border: 1rpx solid #dde0d6; /* 鼠尾草描边·tokens 无对应 */
}
.coord-muted {
  background: var(--ld-bg-grey);
  border: 1rpx solid var(--ld-line);
}
.coord-banner-ico {
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: var(--ld-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.coord-banner-img {
  width: 40rpx;
  height: 40rpx;
}
.coord-banner-text {
  flex: 1 1 auto;
  min-width: 0;
}
.coord-banner-head {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ld-ink);
  letter-spacing: -0.3rpx;
}
.coord-banner-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--ld-content-2);
  line-height: 1.5;
}

/* ---------- 物流卡 ---------- */
.coord-logi {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx;
}
.coord-logi-ico {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: var(--ld-bg-lilac);
  display: flex;
  align-items: center;
  justify-content: center;
}
.coord-logi-img {
  width: 30rpx;
  height: 30rpx;
}
.coord-logi-text {
  flex: 1 1 auto;
  min-width: 0;
}
.coord-logi-line {
  font-size: 25rpx;
  color: var(--ld-ink);
  line-height: 1.45;
}
.coord-logi-time {
  margin-top: 7rpx;
  font-size: 20rpx;
  color: var(--ld-content-2);
  letter-spacing: 0.4rpx;
}

/* ---------- 收货地址卡（含彩色针脚底边·设计签名件） ---------- */
.co-addr {
  position: relative;
  background: var(--ld-bg);
  border-radius: var(--ld-radius-md);
  box-shadow: 0 2rpx 4rpx rgba(54, 58, 80, 0.05);
  overflow: hidden;
}
.co-addr-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 34rpx 26rpx 38rpx;
}
.co-addr-pin {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}
.co-addr-text {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.co-addr-line1 {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}
.co-addr-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ld-ink);
  letter-spacing: -0.3rpx;
}
.co-addr-phone {
  font-size: 26rpx;
  color: var(--ld-content);
  letter-spacing: 0.4rpx;
}
.co-addr-line2 {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: var(--ld-content-2);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
/* 彩色针脚底边（小鸭橙 + 幸运紫的手作针脚·设计特有意象） */
.co-stitch {
  height: 8rpx;
  background-image: repeating-linear-gradient(
    72deg,
    var(--ld-duck-deep) 0 11rpx,
    transparent 11rpx 13rpx,
    var(--ld-purple) 13rpx 24rpx,
    transparent 24rpx 26rpx
  );
}

/* ---------- 通用白卡 ---------- */
.co-card {
  background: var(--ld-bg);
  border-radius: var(--ld-radius-md);
  box-shadow: 0 2rpx 4rpx rgba(54, 58, 80, 0.05);
  overflow: hidden;
}

/* 店铺行 */
.co-shop {
  display: flex;
  align-items: center;
  gap: 13rpx;
  padding: 26rpx 30rpx 8rpx;
}
.co-shop-ico {
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 auto;
}
.co-shop-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ld-ink);
}
.co-shop-chev {
  margin-left: auto;
  display: flex;
  align-items: center;
  opacity: 0.6;
}
.co-shop-chev .co-ico {
  width: 30rpx;
  height: 30rpx;
}

/* 订单商品行（只读） */
.co-item {
  display: flex;
  gap: 22rpx;
  padding: 26rpx 30rpx;
}
.co-item-img {
  width: 150rpx;
  height: 150rpx;
  flex: 0 0 auto;
  border-radius: var(--ld-radius-sm);
  background: var(--ld-bg-sage); /* 订单行无商品图字段→灰底占位 */
}
.co-item-mid {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.co-item-name {
  font-size: 28rpx;
  color: var(--ld-ink);
  line-height: 1.35;
  letter-spacing: -0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.co-item-spec {
  align-self: flex-start;
  margin-top: 13rpx;
  font-size: 22rpx;
  color: var(--ld-content-2);
  background: var(--ld-bg-grey);
  border-radius: 8rpx;
  padding: 6rpx 15rpx;
}
.co-item-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 18rpx;
}
.co-price {
  font-weight: 600;
  color: var(--ld-ink);
  letter-spacing: 0.4rpx;
}
.co-item-price {
  font-size: 34rpx;
}
.co-item-footright {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}
.co-item-qty {
  font-size: 25rpx;
  color: var(--ld-content-2);
  letter-spacing: 0.4rpx;
}
.coord-review {
  font-size: 22rpx;
  color: var(--ld-purple-tab);
  border: 1rpx solid var(--ld-purple-line);
  border-radius: var(--ld-radius-pill);
  padding: 7rpx 22rpx;
}

/* ---------- 订单信息行 ---------- */
.co-rows {
  padding: 4rpx 0;
}
.co-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 30rpx;
}
.co-row + .co-row {
  border-top: 1rpx solid var(--ld-line-soft);
}
.co-row-key {
  flex: 0 0 auto;
  font-size: 27rpx;
  color: var(--ld-content);
}
.co-row-val {
  flex: 1 1 auto;
  text-align: right;
  font-size: 26rpx;
  color: var(--ld-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.co-row-val.muted {
  color: var(--ld-content-2);
}
.co-row-mono {
  letter-spacing: 0.6rpx;
}
.coord-copy {
  flex: 0 0 auto;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.coord-copy-img {
  width: 30rpx;
  height: 30rpx;
}

/* ---------- 金额明细（灰色内嵌盒） ---------- */
.co-summary {
  margin: 8rpx 22rpx 26rpx;
  background: #f7f7f8; /* 设计明细盒浅灰底·tokens 无对应 */
  border-radius: var(--ld-radius-md);
  padding: 26rpx 30rpx;
}
.co-sum-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}
.co-sum-row text {
  font-size: 25rpx;
  color: var(--ld-content-2);
}
.co-sum-v {
  font-weight: 500;
  color: var(--ld-content) !important;
  letter-spacing: 0.4rpx;
}
.co-sum-row.discount .co-sum-v {
  color: var(--ld-purple) !important; /* 券抵扣沿 cart 用幸运紫强调（mp 无 red token） */
}
.co-sum-div {
  height: 1rpx;
  background: var(--ld-line);
  margin: 13rpx 0;
}
.co-sum-row.total text {
  font-size: 26rpx;
  color: var(--ld-ink);
}
.co-sum-row.total .co-sum-v {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ld-ink) !important;
}

/* 申请售后：金额明细下方独立小按钮 */
.coord-refund-wrap {
  display: flex;
  justify-content: flex-end;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid var(--ld-line-soft);
}
.coord-refund {
  display: inline-flex;
  align-items: center;
  gap: 9rpx;
  height: 60rpx;
  padding: 0 26rpx;
  border-radius: var(--ld-radius-pill);
  border: 1rpx solid var(--ld-purple-line);
  background: var(--ld-bg);
  font-size: 24rpx;
  color: var(--ld-content);
}
.coord-refund-img {
  width: 28rpx;
  height: 28rpx;
}

/* ---------- 底部坞 ---------- */
.co-dock-space {
  height: 170rpx;
}
.co-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--ld-bg);
  box-shadow: 0 -2rpx 0 var(--ld-line), 0 -8rpx 24rpx rgba(54, 58, 80, 0.06);
}
.co-dockbar {
  display: flex;
  align-items: center;
  gap: 26rpx;
  padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom)) 34rpx;
}
.co-dock-total {
  display: flex;
  flex-direction: column;
  line-height: 1.15;
}
.co-dock-small {
  font-size: 20rpx;
  color: var(--ld-content-2);
}
.co-dock-amount {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.co-dock-num {
  font-size: 46rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
  letter-spacing: 0.2rpx;
  line-height: 1;
}
.co-dock-num .cny {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 2rpx;
}
.co-submit {
  margin-left: auto;
  flex: 0 0 auto;
  padding: 24rpx 56rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
/* 取消订单（待支付·次级 ghost·与继续支付并列右侧·margin-left:auto 把按钮组推到右边） */
.co-cancel {
  margin-left: auto;
  flex: 0 0 auto;
  padding: 24rpx 36rpx;
  border-radius: var(--ld-radius-pill);
  background: transparent;
  border: 1rpx solid var(--ld-line);
  color: var(--ld-content-2);
  font-size: 30rpx;
  font-weight: 600;
}

/* ---------- 订单不存在 ---------- */
.coord-empty {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.coord-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ld-purple-ink);
}
.coord-empty-hint {
  font-size: 24rpx;
  color: var(--ld-content-2);
}
