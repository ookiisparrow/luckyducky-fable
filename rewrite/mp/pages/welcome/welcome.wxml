<!-- 激活欢迎页·对齐设计 Welcome.jsx 变体A「沉浸全屏」+ 播放器重设计战役批E 新增 W1/W2 lilac 壳。
     业务态：phase 'input'（输入激活码）/ 'result'（兑课结果）/ 'w2'（W2 三件事屏·仅新激活可达）。
     kind==='mine'/'taken'/'invalid' 三态与输入态一律走沉浸全屏照片壳（第一个 view，一字不动）；
     唯独 kind==='activated' 改走 W1（恭喜屏）→ W2（三件事屏）两屏 lilac 壳（第二/三个 view，本批新增）。
     数据流与 handler 全保留（activate/onEnter/onRetry/onGoHome），新增 onNextWelcome（W1→W2 纯前端翻屏）。 -->

<!-- 沉浸全屏照片壳：input 态 + result 态里 kind !== 'activated'（mine/欢迎回来·taken/已被使用·invalid/废码） -->
<view class="ld-welcome" wx:if="{{phase === 'input' || (phase === 'result' && kind !== 'activated')}}">
  <image wx:if="{{bg}}" class="ld-w-photo" src="{{bg}}" mode="aspectFill" />
  <view wx:else class="ld-w-photo ld-w-photo-empty"></view>
  <view class="ld-w-scrim"></view>

  <image class="ld-w-logo" src="/static/logo-wordmark.svg" mode="heightFix" style="top: {{statusBarHeight + 40}}px" />

  <view class="ld-w-body">
    <block wx:if="{{phase === 'input'}}">
      <view class="ld-w-eyebrow">ACTIVATION · 激活课程</view>
      <view class="ld-w-display">激活你的课程</view>
      <view class="ld-w-lead">输入材料包里激活卡上的激活码，一针一线开启你的钩织之旅。</view>
      <input class="ld-w-input" value="{{code}}" bind:input="onInput" placeholder="LD 开头的激活码" placeholder-class="ld-w-ph" confirm-type="done" bind:confirm="onActivate" />
      <view class="ld-w-cta {{busy ? 'dim' : ''}}" bind:tap="onActivate">
        <text>激活</text>
        <image class="ld-w-cta-ico" src="/static/icons/arrow-right.svg" mode="aspectFit" />
      </view>
    </block>

    <block wx:elif="{{kind === 'mine'}}">
      <view class="ld-w-eyebrow">WELCOME BACK · 欢迎回来</view>
      <view class="ld-w-display">欢迎回来</view>
      <view class="ld-w-lead">这个码已经是你的了，接着上次继续钩就好，慢慢来。</view>
      <view class="ld-w-cta" bind:tap="onEnter">
        <text>继续学习</text>
        <image class="ld-w-cta-ico" src="/static/icons/arrow-right.svg" mode="aspectFit" />
      </view>
    </block>

    <block wx:elif="{{kind === 'taken'}}">
      <view class="ld-w-eyebrow">NOTICE · 已被使用</view>
      <view class="ld-w-display">这个码已被使用</view>
      <view class="ld-w-lead">它已经被别的账号激活了。如果是家人朋友，让 TA 用自己的手机继续学；买过材料包想自己学，用包里你自己的码。</view>
      <view class="ld-w-cta ghost" bind:tap="onRetry">
        <text>换一个码试试</text>
        <image class="ld-w-cta-ico" src="/static/icons/rotate-ccw-on.svg" mode="aspectFit" />
      </view>
    </block>

    <!-- 网络失败态（深审20260712 P3·与废码分治）：码可能没问题，只是没连上——重试用原码再发，不清码不误导 -->
    <block wx:elif="{{kind === 'error'}}">
      <view class="ld-w-eyebrow">NETWORK · 网络开小差</view>
      <view class="ld-w-display">网络没连上</view>
      <view class="ld-w-lead">你的激活码可能没问题，只是刚才没连上服务器——稍等片刻，再试一次就好。</view>
      <view class="ld-w-cta ghost {{busy ? 'dim' : ''}}" bind:tap="onActivate">
        <text>再试一次</text>
        <image class="ld-w-cta-ico" src="/static/icons/rotate-ccw-on.svg" mode="aspectFit" />
      </view>
    </block>

    <block wx:else>
      <view class="ld-w-eyebrow">OOPS · 激活码有误</view>
      <view class="ld-w-display">激活码不对哦</view>
      <view class="ld-w-lead">检查一下大小写和有没有抄漏——找不到码可以联系客服帮你确认。</view>
      <view class="ld-w-cta ghost" bind:tap="onRetry">
        <text>重新输入</text>
        <image class="ld-w-cta-ico" src="/static/icons/rotate-ccw-on.svg" mode="aspectFit" />
      </view>
    </block>
  </view>
</view>

<!-- W1 恭喜屏（kind==='activated' 的 result 屏）：lilac 底·产品主图卡·课程名·「下一步」纯前端翻屏 -->
<view class="ld-wl" wx:elif="{{phase === 'result' && kind === 'activated'}}">
  <view class="ld-wl-body" style="padding-top: {{statusBarHeight + 24}}px">
    <view class="ld-wl-brand">LUCKY DUCKY · 小棉鸭课堂</view>
    <image wx:if="{{bg}}" class="ld-wl-hero" src="{{bg}}" mode="aspectFill" />
    <view wx:else class="ld-wl-hero ld-wl-hero-empty"></view>
    <view class="ld-wl-copy">
      <view class="ld-wl-title">{{welcome.w1.title}}</view>
      <view class="ld-wl-course" wx:if="{{courseTitle}}">{{courseTitle}}</view>
      <view class="ld-wl-lead">{{welcome.w1.sub}}</view>
    </view>
    <view class="ld-wl-foot">
      <view class="ld-wl-dots">
        <view class="ld-wl-dot on"></view>
        <view class="ld-wl-dot"></view>
      </view>
      <view class="ld-wl-cta" bind:tap="onNextWelcome">
        <text>下一步</text>
        <image class="ld-wl-cta-ico" src="/static/icons/arrow-right.svg" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>

<!-- W2 三件事屏：lilac 底·三点卡·不可退货警示·「进入课程」走既有 onEnter -->
<view class="ld-wl" wx:elif="{{phase === 'w2'}}">
  <view class="ld-wl-body" style="padding-top: {{statusBarHeight + 24}}px">
    <view class="ld-wl-brand">LUCKY DUCKY · 小棉鸭课堂</view>
    <view class="ld-wl-points">
      <view class="ld-wl-points-title">开始前，想让你知道三件事</view>
      <!-- 三点位固定 onboarding·图标与位置绑定（CMS 只覆盖 title/desc，图标恒取默认槽位·见 lib/mapPages mapWelcome） -->
      <view class="ld-wl-point" wx:for="{{welcome.w2.items}}" wx:key="icon">
        <image class="ld-wl-point-ico" src="/static/icons/{{item.icon}}.svg" mode="aspectFit" />
        <view class="ld-wl-point-tx">
          <view class="ld-wl-point-h">{{item.title}}</view>
          <view class="ld-wl-point-p">{{item.desc}}</view>
        </view>
      </view>
    </view>
    <view class="ld-wl-foot">
      <view class="ld-wl-dots">
        <view class="ld-wl-dot"></view>
        <view class="ld-wl-dot on"></view>
      </view>
      <!-- 不可退货警示（业务告知义务·README 走查表第12项明确要求，不省）·空则强制回默认（mapWelcome·不允许被清空） -->
      <view class="ld-wl-warn">{{welcome.w1.warning}}</view>
      <view class="ld-wl-cta {{busy ? 'dim' : ''}}" bind:tap="onEnter">
        <text>进入课程</text>
        <image class="ld-wl-cta-ico" src="/static/icons/arrow-right.svg" mode="aspectFit" />
      </view>
      <view class="ld-wl-link" bind:tap="onGoHome">先逛逛，稍后再进课</view>
    </view>
  </view>
</view>
