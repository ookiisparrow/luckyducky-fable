/* 激活欢迎页·对齐设计 Welcome.jsx 变体A「沉浸全屏」。设计 402px 画板 → rpx（×1.87）。
   全屏照片铺底 + 双段暗渐 scrim + 顶部字标 + 底部锚定文案与胶囊 CTA；白字浮于暗照之上。
   token 见 styles/tokens.wxss；照片局部暗色为设计专属值、就地写 hex+注释、不改 tokens。 */
.ld-welcome {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #14121a; /* 设计沉浸底(照片缺席兜底暗色)·局部专属·非 token */
}

/* 全屏照片 / 缺席占位（灰底不裂图，白字靠底部 scrim 压暗仍可读） */
.ld-w-photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.ld-w-photo-empty {
  background: #c7c7ca; /* 设计占位照灰(#c7c7ca)·中灰托白字标·局部专属非 token */
}

/* 双段暗渐 scrim：顶部微压(字标可读) + 底部重压(文案区) */
.ld-w-scrim {
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(to bottom, rgba(20, 18, 26, 0.42) 0%, rgba(20, 18, 26, 0) 24%),
    linear-gradient(to top, rgba(20, 18, 26, 0.86) 0%, rgba(20, 18, 26, 0.4) 40%, rgba(20, 18, 26, 0) 66%);
}

/* 顶部品牌字标（烘反白·投影保底可读） */
.ld-w-logo {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  height: 64rpx;
  width: auto;
  z-index: 3;
  filter: brightness(0) invert(1) drop-shadow(0 2rpx 10rpx rgba(0, 0, 0, 0.35));
}

/* 底部锚定文案区（min-height:100vh + margin-top:auto 顶到底·正常流以便键盘抬升） */
.ld-w-body {
  position: relative;
  z-index: 2;
  margin-top: auto;
  padding: 0 56rpx calc(96rpx + env(safe-area-inset-bottom));
  color: #fff;
}
.ld-w-eyebrow {
  font-size: 21rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  opacity: 0.9;
}
.ld-w-display {
  margin-top: 22rpx;
  font-size: 76rpx;
  font-weight: 700;
  line-height: 1.12;
  letter-spacing: -1rpx;
  text-shadow: 0 3rpx 30rpx rgba(0, 0, 0, 0.32);
}
.ld-w-lead {
  margin-top: 26rpx;
  max-width: 560rpx;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.62;
  opacity: 0.94;
  text-shadow: 0 2rpx 14rpx rgba(0, 0, 0, 0.3);
}

/* 沉浸态输入框：半透明白磨砂域（无 backdrop-filter·css-compat 禁）+ 白描边白字居中 */
.ld-w-input {
  margin-top: 40rpx;
  width: 100%;
  height: 100rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 24rpx;
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  letter-spacing: 4rpx;
}
.ld-w-ph {
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 2rpx;
}

/* 胶囊 CTA（设计 wel-cta-dark：深紫墨 + 阴影） */
.ld-w-cta {
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 104rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple-ink);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 12rpx 34rpx rgba(28, 28, 32, 0.32);
}
.ld-w-cta-ico {
  width: 34rpx;
  height: 34rpx;
}
/* 次要 CTA（换码/重输）：半透明白磨砂 + 白描边 */
.ld-w-cta.ghost {
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  box-shadow: none;
}
.ld-w-cta.dim {
  opacity: 0.5;
}

/* 安静文本链接（先逛逛稍后再进课） */
.ld-w-link {
  margin-top: 24rpx;
  text-align: center;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.82);
  text-decoration: underline;
}
