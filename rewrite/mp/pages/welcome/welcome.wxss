.ld-welcome {
  min-height: 100vh;
  background: var(--ld-bg-lilac);
  position: relative;
}
.ld-w-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.ld-w-body {
  position: relative;
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  text-align: center;
}
.ld-w-title {
  margin-top: 120rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
}
.ld-w-sub {
  font-size: 26rpx;
  color: var(--ld-purple-meta);
  line-height: 1.6;
  max-width: 560rpx;
}
.ld-w-input {
  margin-top: 32rpx;
  width: 100%;
  padding: 26rpx 32rpx;
  background: var(--ld-bg);
  border: 2rpx solid var(--ld-purple-line);
  border-radius: var(--ld-radius);
  font-size: 30rpx;
  text-align: center;
  letter-spacing: 4rpx;
}
.ld-w-btn {
  margin-top: 32rpx;
  width: 100%;
  text-align: center;
  padding: 26rpx 0;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple-ink);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
.ld-w-btn.ghost {
  background: var(--ld-bg);
  color: var(--ld-purple-tab);
  border: 2rpx solid var(--ld-purple-line);
}
.ld-w-btn.dim {
  opacity: 0.5;
}
.ld-w-link {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
  text-decoration: underline;
}
