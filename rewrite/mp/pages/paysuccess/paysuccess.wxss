/* 支付成功页 · 设计 PaySuccess（cosuc）。设计稿 402px 画板 → rpx（×1.87）。
   token 见 styles/tokens.wxss。白底、顶对齐可滚：英雄对勾 + 实付金额 + 订单信息盒 + 双动作 + 小尾巴。
   业务逻辑（回首页/看订单）由 paysuccess.ts handler 承接，本文件只管视觉。 */
.ld-paysuccess {
  min-height: 100vh;
  background: var(--ld-bg);
  padding: 34rpx 38rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

/* ---------- 英雄区 ---------- */
.ld-ps-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 56rpx 22rpx 48rpx;
}
.ld-ps-check {
  width: 142rpx;
  height: 142rpx;
  border-radius: 50%;
  background: var(--ld-purple);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 52rpx rgba(123, 92, 175, 0.32); /* 紫投影·呼应 --ld-purple-tab #7b5caf */
}
.ld-ps-check-ico {
  width: 74rpx;
  height: 74rpx;
}
.ld-ps-title {
  margin-top: 38rpx;
  font-size: 45rpx;
  font-weight: 700;
  color: var(--ld-ink);
  letter-spacing: -0.4rpx;
}
.ld-ps-amount {
  margin-top: 18rpx;
  font-size: 64rpx;
  font-weight: 700;
  color: var(--ld-ink);
  letter-spacing: 0.4rpx;
  line-height: 1;
}
.ld-ps-cny {
  font-size: 38rpx;
  font-weight: 600;
  margin-right: 4rpx;
}
.ld-ps-sub {
  margin-top: 22rpx;
  max-width: 486rpx;
  font-size: 26rpx;
  color: var(--ld-content-2);
  line-height: 1.6;
}

/* ---------- 订单信息盒 ---------- */
.ld-ps-info {
  margin-top: 12rpx;
  padding: 12rpx 30rpx;
  border-radius: var(--ld-radius-md);
  background: #f7f7f8; /* 设计局部浅灰盒·token 无此值 */
}
.ld-ps-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--ld-line);
}
.ld-ps-info-row:last-child {
  border-bottom: none;
}
.ld-ps-info-k {
  flex: 0 0 auto;
  font-size: 25rpx;
  color: var(--ld-content-2);
}
.ld-ps-info-v {
  flex: 1 1 auto;
  min-width: 0;
  text-align: right;
  font-size: 26rpx;
  color: var(--ld-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ld-ps-info-v.mono {
  letter-spacing: 0.4rpx;
}

/* ---------- 双动作 ---------- */
.ld-ps-actions {
  display: flex;
  gap: 22rpx;
  margin-top: 48rpx;
}
.ld-ps-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  border-radius: var(--ld-radius-pill);
  font-size: 30rpx;
  font-weight: 600;
}
.ld-ps-btn.ghost {
  background: var(--ld-bg);
  border: 2rpx solid var(--ld-purple);
  color: var(--ld-purple);
  line-height: 86rpx; /* 抵边框 2rpx×2 保持垂直居中 */
}
.ld-ps-btn.solid {
  background: var(--ld-purple);
  color: #ffffff;
}
.ld-ps-btn-hover {
  opacity: 0.88;
}

/* ---------- 幸运小尾巴 ---------- */
.ld-ps-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin: 42rpx auto 0;
  max-width: 524rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
  line-height: 1.5;
}
.ld-ps-tip-ico {
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 auto;
}
