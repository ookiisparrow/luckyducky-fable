.ld-cart {
  min-height: 100vh;
  background: var(--ld-bg-lilac);
  padding: 24rpx 24rpx 0;
}
.ld-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: var(--ld-bg);
  border-radius: var(--ld-radius);
  border: 2rpx solid var(--ld-purple-line);
}
.ld-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid var(--ld-purple-line);
  flex-shrink: 0;
}
.ld-check.on {
  background: var(--ld-purple-tab);
  border-color: var(--ld-purple-tab);
}
.ld-row-media {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: var(--ld-bg-sage);
  flex-shrink: 0;
}
.ld-row-main {
  flex: 1;
  min-width: 0;
}
.ld-row-name {
  font-size: 28rpx;
  color: var(--ld-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ld-row-sku {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ld-purple-meta);
}
.ld-row-bottom {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ld-row-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
}
.ld-stepper {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.ld-step {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 2rpx solid var(--ld-purple-line);
  color: var(--ld-purple-tab);
  font-size: 32rpx;
}
.ld-step.dim {
  opacity: 0.35;
}
.ld-step-qty {
  min-width: 64rpx;
  text-align: center;
  font-size: 28rpx;
}
.ld-row-del {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
  padding: 12rpx;
}
.ld-checkoutbar-space {
  height: 220rpx;
}
.ld-checkoutbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(140rpx + env(safe-area-inset-bottom)); /* 让开悬浮 TabBar */
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 24rpx;
  padding: 20rpx 24rpx;
  background: var(--ld-bg);
  border-radius: var(--ld-radius);
  box-shadow: 0 8rpx 32rpx rgba(36, 23, 51, 0.12);
}
.ld-selectall {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
.ld-total {
  flex: 1;
  text-align: right;
}
.ld-total-label {
  font-size: 24rpx;
  color: var(--ld-purple-meta);
  margin-right: 8rpx;
}
.ld-total-num {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
}
.ld-gobtn {
  padding: 20rpx 40rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple-ink);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}
.ld-gobtn.dim {
  opacity: 0.4;
}
.ld-cart-empty {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: var(--ld-bg-lilac);
}
.ld-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ld-purple-ink);
}
.ld-empty-hint {
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
.ld-empty-btn {
  margin-top: 24rpx;
  padding: 18rpx 64rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple-ink);
  color: #ffffff;
  font-size: 28rpx;
}
