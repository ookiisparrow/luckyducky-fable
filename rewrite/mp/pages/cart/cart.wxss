/* 购物车·设计「待选区」语言。设计稿 402px 画板 → rpx（×1.87）。
   token 见 styles/tokens.wxss；标题头 + 虚线暂存区(已加购行) + 下方推荐(圆加号) + 信任小字 + 悬浮结算 bar。
   业务逻辑（勾选/加减/删除/全选/合计/结算·lib/cart）由 wxml handler 承接，本文件只管视觉。 */
.ld-cart {
  min-height: 100vh;
  background: var(--ld-bg-lilac);
  padding: 24rpx 0 0;
}

/* 标题头 */
.ld-cart-head {
  padding: 12rpx 36rpx 0;
}
.ld-cart-title {
  font-size: 52rpx;
  font-weight: 500;
  line-height: 1.2;
  color: var(--ld-ink);
  letter-spacing: -0.5rpx;
}
.ld-cart-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--ld-content-2);
}

/* 待选区（虚线暂存区） */
.ld-cart-hold {
  margin: 30rpx 36rpx 8rpx;
}
.ld-cart-hold-empty {
  height: 400rpx;
  border-top: 4rpx dashed var(--ld-purple);
  border-bottom: 4rpx dashed var(--ld-purple);
  display: flex;
  align-items: center;
  justify-content: center;
}
.ld-cart-hold-hint {
  font-size: 24rpx;
  color: var(--ld-content-2);
  letter-spacing: 2rpx;
}
.ld-cart-hold-list {
  border-top: 4rpx dashed var(--ld-purple);
  border-bottom: 4rpx dashed var(--ld-purple);
  padding: 4rpx 0;
  margin-bottom: 40rpx;
}

/* 行（待选区 + 推荐共用） */
.ld-cart-row {
  display: flex;
  align-items: center;
  gap: 26rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--ld-line-soft);
}
.ld-cart-row:last-child {
  border-bottom: none;
}
.ld-check {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 3rpx solid var(--ld-purple-line);
  flex: 0 0 auto;
}
.ld-check.on {
  background: var(--ld-purple-tab);
  border-color: var(--ld-purple-tab);
}
.ld-cart-row-img {
  width: 164rpx;
  height: 164rpx;
  flex: 0 0 auto;
  border-radius: var(--ld-radius-md);
  overflow: hidden;
  background: var(--ld-bg-sage);
}
.ld-cart-hold-list .ld-cart-row-img {
  width: 194rpx;
  height: 194rpx;
}
.ld-cart-row-photo {
  width: 100%;
  height: 100%;
}
.ld-cart-row-mid {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.ld-cart-row-name {
  font-size: 28rpx;
  line-height: 1.35;
  color: var(--ld-ink);
  letter-spacing: -0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ld-cart-hold-list .ld-cart-row-name {
  font-size: 30rpx;
}
.ld-cart-row-tag {
  font-size: 22rpx;
  color: var(--ld-content-2);
}
.ld-cart-row-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 2rpx;
}
.ld-cart-was {
  font-size: 20rpx;
  color: var(--ld-content-2);
  text-decoration: line-through;
}
.ld-cart-now {
  font-size: 34rpx;
  font-weight: 600;
  color: #222222;
  letter-spacing: 0.4rpx;
}

/* 动作列 */
.ld-cart-row-act {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
}
.ld-stepper {
  display: flex;
  align-items: center;
  border: 2rpx solid var(--ld-purple-line);
  border-radius: var(--ld-radius-pill);
  overflow: hidden;
}
.ld-step {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  background: #ffffff;
  color: var(--ld-ink);
  font-size: 32rpx;
}
.ld-step.dim {
  color: var(--ld-purple-line);
}
.ld-step-qty {
  min-width: 56rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--ld-ink);
  background: #ffffff;
}
.ld-cart-row-del {
  font-size: 22rpx;
  color: var(--ld-content-2);
  padding: 4rpx 8rpx;
}
.ld-cart-add {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--ld-purple);
  color: #ffffff;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 下方推荐 */
.ld-cart-recs {
  margin: 0 36rpx;
}
.ld-cart-recs-title {
  margin-bottom: 4rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ld-ink);
}

/* 信任小字 */
.ld-cart-trust {
  margin: 30rpx 36rpx 0;
  padding-top: 26rpx;
  border-top: 1rpx solid var(--ld-line-soft);
  font-size: 22rpx;
  color: var(--ld-content-2);
  text-align: center;
  letter-spacing: 2rpx;
}

/* 悬浮结算 bar */
.ld-checkbar-space {
  height: 340rpx;
}
.ld-checkbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(140rpx + env(safe-area-inset-bottom)); /* 让开悬浮 TabBar */
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 24rpx;
  padding: 18rpx 20rpx 18rpx 28rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 12rpx 44rpx rgba(28, 28, 32, 0.16), 0 2rpx 8rpx rgba(28, 28, 32, 0.1);
}
.ld-selectall {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--ld-content-2);
}
.ld-checkbar-total {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  line-height: 1.1;
}
.ld-checkbar-label {
  font-size: 20rpx;
  color: var(--ld-content-2);
}
.ld-checkbar-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
  letter-spacing: 0.4rpx;
}
.ld-checkbar.empty .ld-checkbar-num {
  color: #bdbdbd;
}
.ld-checkout-btn {
  flex: 0 0 auto;
  padding: 22rpx 40rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}
.ld-checkout-btn.dim {
  background: var(--ld-purple-line);
}
