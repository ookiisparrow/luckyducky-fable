<view class="ld-rv-page">
  <!-- 评分摘要：大号均分 + 星 + 分布条 + 标签 chip（真实 summary·条数 0 时 mapSummary 返 null 不渲染） -->
  <view class="ld-rv-summary" wx:if="{{summary}}">
    <view class="ld-rv-head">
      <view class="ld-rv-score">
        <text class="ld-rv-num">{{summary.scoreLabel}}</text>
        <text class="ld-rv-stars ld-rv-stars-lg">{{summary.scoreStars}}</text>
        <text class="ld-rv-count">{{summary.count}} 条评价</text>
      </view>
      <view class="ld-rv-bars">
        <view class="ld-rv-bar" wx:for="{{summary.dist}}" wx:key="label">
          <text class="ld-rv-bar-lbl">{{item.label}}</text>
          <view class="ld-rv-track"><view class="ld-rv-fill" style="width: {{item.pct}}%"></view></view>
        </view>
      </view>
    </view>
    <view class="ld-rv-chips" wx:if="{{summary.tags.length}}">
      <view class="ld-rv-chip" wx:for="{{summary.tags}}" wx:key="tag">{{item.tag}}<text class="ld-rv-chip-n">{{item.n}}</text></view>
    </view>
  </view>

  <!-- 评价列表（游标分页·onReachBottom 追加·守卫 reviews-list-paged） -->
  <!-- wx:key 刻意用 index（批5 预审已核）：ReviewVM 无任何唯一字段，云端 getReviews 刻意不透传 _id
       （orderId__lineId 组合会向其他用户泄露订单信息）；该列表为追加式只读（无删除/重排），index 安全。 -->
  <view class="ld-rv-list" wx:if="{{list.length}}">
    <view class="ld-rv-item" wx:for="{{list}}" wx:key="index">
      <view class="ld-rv-item-top">
        <view class="ld-rv-av"></view>
        <text class="ld-rv-name">{{item.name}}</text>
        <text class="ld-rv-date">{{item.timeLabel}}</text>
      </view>
      <text class="ld-rv-stars">{{item.stars}}</text>
      <view class="ld-rv-spec" wx:if="{{item.spec}}">{{item.spec}}</view>
      <text class="ld-rv-text" wx:if="{{item.text}}">{{item.text}}</text>
      <view class="ld-rv-photos" wx:if="{{item.photos.length}}">
        <image
          wx:for="{{item.photos}}"
          wx:for-item="ph"
          wx:key="*this"
          class="ld-rv-photo"
          src="{{ph}}"
          mode="aspectFill"
          lazy-load
          data-url="{{ph}}"
          data-urls="{{item.photos}}"
          bind:tap="onPreviewPhoto"
        />
      </view>
      <view class="ld-rv-tagrow" wx:if="{{item.tags.length}}">
        <text class="ld-rv-tag" wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
      </view>
    </view>
  </view>

  <!-- 骨架占位（加载中且列表空时不再整页空白·根因#8）：微光扫过对齐 home/catalog（@keyframes ld-shimmer·
       app.wxss）。尺寸照真卡量：头像 52rpx 复用 .ld-rv-av、图 200rpx 复用 .ld-rv-photo·两行文案条 + 图格。 -->
  <view class="ld-rv-list" wx:if="{{loading && !list.length}}">
    <view class="ld-rv-item ld-rv-skel" wx:for="{{[1, 2, 3]}}" wx:key="*this">
      <view class="ld-rv-item-top">
        <view class="ld-rv-av ld-rv-skel-block"></view>
        <view class="ld-rv-skel-bar" style="width: 160rpx"></view>
      </view>
      <view class="ld-rv-skel-bar" style="width: 86%"></view>
      <view class="ld-rv-skel-bar" style="width: 58%"></view>
      <view class="ld-rv-skel-photos">
        <view class="ld-rv-photo ld-rv-skel-block" wx:for="{{[1, 2, 3]}}" wx:for-item="p" wx:key="*this"></view>
      </view>
    </view>
  </view>

  <!-- 失败态与空态分治（根因#14·守卫 rw-mp-list-loadfailed-state） -->
  <view class="ld-rv-empty" wx:if="{{!loading && loadFailed}}">
    <view class="ld-empty-title">网络开小差</view>
    <view class="ld-empty-hint">评价没加载出来，请重试</view>
    <view class="ld-rv-retry" bind:tap="onRetryLoad">重试</view>
  </view>
  <view class="ld-rv-empty" wx:elif="{{!loading && !list.length}}">
    <view class="ld-empty-title">还没有评价</view>
    <view class="ld-empty-hint">买过的钩友完成订单后可以来写第一条</view>
  </view>
  <view class="ld-rv-more" wx:if="{{hasMore}}">上拉加载更多</view>
</view>
