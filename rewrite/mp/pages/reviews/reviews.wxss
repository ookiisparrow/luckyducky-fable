/* 全部评价·重设计对齐 ProductDetail.jsx ReviewsPage（评分摘要+分布条+标签 chip+评价列表）。
   设计 402px 画板→rpx（×1.87）。灰底全宽白卡·发丝线分隔行；token 见 styles/tokens.wxss。 */
.ld-rv-page {
  min-height: 100vh;
  background: var(--ld-bg-grey);
  padding-bottom: 40rpx;
}

/* 评分摘要（白卡全宽） */
.ld-rv-summary {
  background: var(--ld-bg);
}
.ld-rv-head {
  display: flex;
  align-items: center;
  gap: 36rpx;
  padding: 28rpx 38rpx 16rpx;
}
.ld-rv-score {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.ld-rv-num {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--ld-ink);
}
.ld-rv-count {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ld-content-2);
}
.ld-rv-bars {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.ld-rv-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ld-rv-bar-lbl {
  width: 60rpx;
  font-size: 22rpx;
  color: var(--ld-content-2);
}
.ld-rv-track {
  flex: 1;
  height: 10rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-line);
  overflow: hidden;
}
.ld-rv-fill {
  height: 100%;
  background: var(--ld-duck-deep);
  border-radius: var(--ld-radius-pill);
}

/* 星（鸭黄暖点） */
.ld-rv-stars {
  color: var(--ld-duck-deep);
  font-size: 24rpx;
  letter-spacing: 3rpx;
}
.ld-rv-stars-lg {
  margin-top: 8rpx;
  font-size: 26rpx;
}

/* 标签 chip */
.ld-rv-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 12rpx 38rpx 26rpx;
}
.ld-rv-chip {
  padding: 12rpx 22rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-bg-grey);
  font-size: 24rpx;
  color: var(--ld-content);
}
.ld-rv-chip-n {
  margin-left: 6rpx;
  color: var(--ld-content-2);
}

/* 评价列表（白卡全宽·行间发丝线） */
.ld-rv-list {
  margin-top: 20rpx;
  background: var(--ld-bg);
}
.ld-rv-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 26rpx 38rpx;
  border-top: 2rpx solid var(--ld-line-soft);
}
.ld-rv-item:first-child {
  border-top: none;
}
.ld-rv-item-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ld-rv-av {
  flex: 0 0 auto;
  width: 52rpx;
  height: 52rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-bg-sage);
}
.ld-rv-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--ld-ink);
}
.ld-rv-date {
  font-size: 22rpx;
  color: var(--ld-content-2);
}
.ld-rv-spec {
  font-size: 22rpx;
  color: var(--ld-content-2);
}
.ld-rv-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--ld-content);
}
/* 买家秀晒图（评价卡内九宫格·点开大图） */
.ld-rv-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.ld-rv-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--ld-radius-sm);
  background: var(--ld-bg-sage);
}
.ld-rv-tagrow {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.ld-rv-tag {
  padding: 8rpx 18rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-bg-grey);
  font-size: 22rpx;
  color: var(--ld-content-2);
}

/* 空态 / 加载更多 */
.ld-rv-empty {
  padding: 140rpx 0;
  text-align: center;
}
.ld-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ld-purple-ink);
}
.ld-empty-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--ld-content-2);
}
.ld-rv-more {
  padding: 24rpx 0;
  text-align: center;
  font-size: 22rpx;
  color: var(--ld-content-2);
}

/* 失败态重试钮（根因#14·守卫 rw-mp-list-loadfailed-state·形制同 detail pdp-empty-btn） */
.ld-rv-retry {
  display: inline-block;
  margin-top: 18rpx;
  padding: 14rpx 46rpx;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}
