/* 首页重设计 9 板块。设计稿 402px 画板 → rpx（750/402≈1.87 换算·保比例）。
   token 见 styles/tokens.wxss；图标 <image> 引 static/icons/*.svg（色已烘进 svg）。 */
.ld-home {
  background: var(--ld-bg);
  overflow: hidden;
}

/* 通用排版 */
.ld-display {
  font-size: 90rpx;
  font-weight: 700;
  line-height: 1;
  color: #000;
  letter-spacing: -1rpx;
}
.ld-h1 {
  font-size: 60rpx;
  font-weight: 500;
  line-height: 1.2;
  color: #000;
}
.ld-h2 {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #000;
}
.ld-center {
  text-align: center;
}

/* ① HERO */
.ld-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background: var(--ld-bg-sage);
  overflow: hidden;
}
.ld-hero-photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.ld-glogo {
  position: absolute;
  left: 36rpx;
  height: 56rpx;
  width: auto;
  z-index: 3;
  filter: drop-shadow(0 1rpx 3rpx rgba(255, 255, 255, 0.9));
}
.ld-hero-scrim {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 780rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.55) 55%, rgba(255, 255, 255, 0.92));
}
.ld-hero-copy {
  position: relative;
  z-index: 2;
  padding: 0 36rpx 320rpx; /* 抬高文案：坐落鸭图下方（鸭身止于约 59% 高·下半被 scrim 洗白）·不贴 TabBar·不过于偏下（用户反馈 2026-07-16·真机为准） */
  text-align: center;
}
.ld-hero-tag {
  display: block;
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #000;
  letter-spacing: 1rpx;
}
.ld-hero-cta {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 18rpx;
  margin-top: 44rpx;
}
.ld-search {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx solid var(--ld-purple);
  border-radius: var(--ld-radius-pill);
  padding: 22rpx 40rpx;
  min-width: 0;
}
.ld-search-h {
  background: #f7f8ff;
}
.ld-search-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ld-purple);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ld-btn-buy {
  flex: 0 0 auto;
  height: 90rpx;
  padding: 0 48rpx;
  display: flex;
  align-items: center;
  background: var(--ld-purple-ink);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: var(--ld-radius-pill);
}
.ld-btn-buy-h {
  opacity: 0.86;
}

/* ② 品牌介绍 */
.ld-intro {
  padding: 142rpx 36rpx 16rpx;
}
.ld-intro-logo {
  display: block;
  width: 366rpx;
  margin: 0 auto 26rpx;
}
.ld-intro-name {
  font-size: 37rpx;
  font-weight: 500;
  color: var(--ld-content);
  text-align: center;
  letter-spacing: 1rpx;
}
.ld-intro-lead {
  max-width: 616rpx;
  margin: 56rpx auto 0;
  font-size: 34rpx;
  line-height: 1.55;
  color: var(--ld-content);
  text-align: center;
}

/* ③ 特写 + 商品轨 */
.ld-friends {
  padding: 45rpx 36rpx 68rpx;
}
.ld-feature-display {
  position: relative;
  width: 100%;
  padding-top: 100%; /* 方形·padding-top 百分比法（避 aspect-ratio 旧 WebView 不支持） */
  border-radius: var(--ld-radius-md);
  background: var(--ld-bg-sage);
  overflow: hidden;
}
.ld-feature-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.ld-feature-copy {
  margin-top: 118rpx;
}
.ld-feature-title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #000;
}
.ld-feature-body {
  max-width: 75%;
  margin-top: 22rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--ld-content);
}
/* 横向轨走 inline-block（非 scroll-view enable-flex）：卡高=内容高、不被 flex stretch 撑到几十米（真机 bug） */
.ld-prod-rail {
  margin-top: 24rpx;
  white-space: nowrap;
}
.ld-prod-card {
  display: inline-flex;
  flex-direction: column;
  vertical-align: top;
  width: 400rpx;
  /* 与 .ld-review-card 等高（见该规则同款算式注释）：border4+媒体396(1:1方形·卡内容宽396)+padding46(20+26)+name81+tag47(8+39)+foot余量97≈671rpx */
  /* box-sizing:border-box：上方算式把 border4 计入总高，content-box 下 border 会加在 height 之外、实际渲染变 675rpx，须锁 border-box 让声明高度=最终渲染高度 */
  box-sizing: border-box;
  height: 671rpx;
  white-space: normal;
  margin-right: 22rpx;
  background: #fff;
  border: 2rpx solid var(--ld-surface-cream);
  border-radius: var(--ld-radius-sm);
  overflow: hidden;
}
.ld-prod-media {
  position: relative;
  width: 100%;
  padding-top: 100%; /* 1:1 方形（2026-07-13 用户指令·padding-top 百分比法撑方·避 aspect-ratio 旧 WebView 不支持·同 .ld-feature-display） */
  flex-shrink: 0; /* 锁定高度·媒体不被挤扁（同 .ld-review-media） */
  background: var(--ld-bg-sage);
}
.ld-prod-media-img {
  position: absolute; /* padding-top 撑高后子图须绝对铺满方形容器（同 .ld-feature-img） */
  inset: 0;
  width: 100%;
  height: 100%;
}
.ld-prod-body {
  padding: 20rpx 26rpx 26rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.ld-prod-name {
  font-size: 30rpx;
  line-height: 1.35;
  color: var(--ld-ink);
  /* 2 行裁剪钉高：30rpx×1.35×2行＝81rpx（等高不变量：与买家秀卡对齐） */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  height: 81rpx;
}
.ld-prod-tag {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 39rpx; /* 26rpx×1.5＝39rpx，钉死占位高度 */
  color: var(--ld-content-2);
  /* 单行截断：占位高按单行钉死，长文案（后台 tag 最长20字）换行会撑爆 body 挤扁媒体，需强制不换行 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ld-prod-tag-empty {
  visibility: hidden; /* 无 tag 时仍占位，消掉「有无 tag」的高度分叉 */
}
.ld-prod-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto; /* 价格行贴底，body 内余量被吸收（配合 .ld-prod-body 的 flex 列布局） */
}
.ld-price-group {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}
.ld-price-was {
  font-size: 24rpx;
  color: var(--ld-content-2);
  text-decoration: line-through;
}
.ld-price {
  font-size: 40rpx;
  font-weight: 600;
  color: #222;
  letter-spacing: 0.5rpx;
}
.ld-add {
  flex: 0 0 auto;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--ld-purple);
  display: flex;
  align-items: center;
  justify-content: center;
}
.ld-add-h {
  opacity: 0.82;
}
.ld-add-ico {
  width: 34rpx;
  height: 34rpx;
}
.ld-prod-empty {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: var(--ld-content-2);
}
.ld-skeleton,
.ld-skeleton-text {
  background: linear-gradient(90deg, var(--ld-bg-sage) 25%, var(--ld-bg-faint) 50%, var(--ld-bg-sage) 75%);
  background-size: 200% 100%; /* 配 @keyframes ld-shimmer 微光扫过（app.wxss·加载态设计对齐） */
  animation: ld-shimmer 1500ms ease-in-out infinite;
}
.ld-skeleton-text {
  height: 28rpx;
  margin: 16rpx 26rpx;
  border-radius: 8rpx;
}
.ld-skeleton-text.short {
  width: 140rpx;
}

/* ④ 信任条 */
.ld-trust {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  padding: 56rpx 20rpx;
  background: var(--ld-bg-lilac);
  border-top: 1rpx solid #efe9f4;
  border-bottom: 1rpx solid #efe9f4;
}
.ld-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}
.ld-trust-ico {
  width: 44rpx;
  height: 44rpx;
}
.ld-trust-label {
  font-size: 22rpx;
  color: var(--ld-purple-meta);
}

/* ⑤ 拆门槛 + ⑦ FAQ 共用折叠组 */
.ld-reassure {
  padding: 118rpx 36rpx 75rpx;
}
.ld-reassure-head {
  margin-bottom: 38rpx;
}
.ld-h2-left {
  text-align: left;
}
.ld-reassure-lead {
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--ld-content);
}
.ld-collapse {
  border: 2rpx solid var(--ld-line);
  border-radius: var(--ld-radius-md);
  overflow: hidden;
}
.ld-panel {
  background: #fff;
  border-bottom: 2rpx solid var(--ld-line);
}
.ld-panel:last-child {
  border-bottom: none;
}
.ld-panel-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 30rpx;
}
.ld-panel-ico {
  flex: 0 0 auto;
  width: 44rpx;
  height: 44rpx;
}
.ld-panel-title {
  flex: 1;
  text-align: left;
  font-size: 37rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.9);
}
.ld-panel-action {
  flex: 0 0 auto;
  font-size: 28rpx;
  color: var(--ld-content-2);
}
.ld-chev {
  flex: 0 0 auto;
  width: 38rpx;
  height: 38rpx;
  transition: transform 0.25s;
}
.ld-panel.open .ld-chev {
  transform: rotate(180deg);
}
.ld-panel-body {
  padding-bottom: 6rpx;
}
.ld-panel-text {
  padding: 0 30rpx 34rpx 94rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--ld-content);
}
.ld-panel-media {
  margin: 0 30rpx 34rpx;
  height: 460rpx;
  border-radius: var(--ld-radius-md);
  background: var(--ld-bg-sage);
  overflow: hidden;
}
.ld-panel-media-img {
  width: 100%;
  height: 100%;
}

/* ⑥ 买家秀 */
.ld-reviews {
  padding: 56rpx 0;
  background: var(--ld-bg-grey);
}
.ld-reviews-head {
  padding: 0 36rpx 36rpx;
}
/* 同商品轨：inline-flex（内部仍竖排·外部按内容定高）·不被 flex stretch 撑长 */
.ld-review-rail {
  padding: 8rpx 36rpx;
  white-space: nowrap;
}
.ld-review-card {
  display: inline-flex;
  flex-direction: column;
  vertical-align: top;
  width: 400rpx;
  /* 与 .ld-prod-card 等高：border4+媒体396(1:1方形)+padding48(22+26)+星行36+quote上距15+quote120+quote下距22+meta约30＝671rpx */
  /* box-sizing:border-box：让 border4 真被计入 671（.ld-prod-card 同款注释·两卡同步 1:1 方形后内部算式一致不留空隙） */
  box-sizing: border-box;
  height: 671rpx;
  white-space: normal;
  margin-right: 26rpx;
  background: var(--ld-bg-lilac);
  border: 2rpx solid var(--ld-purple-line);
  border-radius: var(--ld-radius-sm);
  overflow: hidden;
  box-shadow: 0 6rpx 8rpx rgba(0, 0, 0, 0.12);
}
.ld-review-media {
  position: relative;
  width: 100%;
  padding-top: 100%; /* 1:1 方形（与商品卡同步·2026-07-13·等高守卫联动两卡内部算式一致不留空隙） */
  flex-shrink: 0; /* 锁定高度·媒体不被挤扁 */
  background: var(--ld-bg-sage);
}
.ld-review-media-img {
  position: absolute; /* padding-top 撑高后子图须绝对铺满方形容器（同 .ld-prod-media-img） */
  inset: 0;
  width: 100%;
  height: 100%;
}
.ld-review-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 22rpx 26rpx 26rpx;
}
.ld-stars {
  font-size: 26rpx;
  line-height: 36rpx; /* 钉死星行高度，纳入卡内容高算式 */
  letter-spacing: 4rpx;
  color: var(--ld-duck-deep);
}
.ld-review-quote {
  margin: 15rpx 0 22rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--ld-ink);
  white-space: normal;
  /* 3 行裁剪钉高：25rpx×1.6×3行＝120rpx */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  height: 120rpx;
}
.ld-review-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
}
.ld-review-dot {
  flex: 0 0 auto;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: var(--ld-purple);
}
.ld-review-user {
  font-size: 21rpx;
  color: var(--ld-content-2);
}
.ld-verified {
  display: flex;
  align-items: center;
  gap: 5rpx;
  margin-left: auto;
  font-size: 22rpx;
  color: var(--ld-purple);
  white-space: nowrap;
}
.ld-verified-ico {
  width: 24rpx;
  height: 24rpx;
}

/* ⑦ FAQ（折叠组·浅紫底无框变体） */
.ld-faq {
  padding: 72rpx 26rpx 82rpx;
  background: var(--ld-bg-lilac);
}
.ld-collapse-faq {
  margin-top: 42rpx;
  border: none;
  background: var(--ld-bg-lilac);
}
.ld-collapse-faq .ld-panel {
  background: var(--ld-bg-lilac);
  border-bottom: 2rpx solid #ece6f2;
}
.ld-collapse-faq .ld-panel-title {
  font-size: 32rpx;
}
.ld-collapse-faq .ld-panel-text {
  padding-left: 30rpx;
}

/* ⑧ 收尾 CTA */
.ld-closing {
  position: relative;
  width: 100%;
  padding-top: 61.8%; /* 黄金比 1 : 0.618·避 aspect-ratio */
  background: #fff;
  overflow: hidden;
}
.ld-closing-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}
.ld-closing-copy {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.ld-closing-title {
  font-size: 75rpx;
  letter-spacing: -1rpx;
}
.ld-btn-dark {
  display: inline-flex;
  align-items: center;
  padding: 28rpx 60rpx;
  background: var(--ld-purple-ink);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--ld-radius-pill);
}
.ld-btn-dark-h {
  opacity: 0.9;
}
.ld-closing-btn {
  margin-top: 42rpx;
  box-shadow: 0 12rpx 40rpx rgba(123, 92, 175, 0.22);
}

/* ⑨ 页脚 */
.ld-footer {
  padding: 68rpx 36rpx calc(210rpx + env(safe-area-inset-bottom));
  background: var(--ld-purple-tab);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.ld-footer-logo {
  height: 75rpx;
  width: auto;
  margin-bottom: 34rpx;
  filter: brightness(0) invert(1);
  opacity: 0.95;
}
.ld-footer-links {
  display: flex;
  align-items: center;
  gap: 18rpx;
  font-size: 24rpx;
}
.ld-footer-link {
  color: #fff;
}
.ld-footer-dot {
  color: rgba(255, 255, 255, 0.6);
}
.ld-footer-copy {
  max-width: 490rpx;
  margin-top: 22rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.75);
}

/* 回到顶部 */
.ld-backtop {
  position: fixed;
  right: 34rpx;
  bottom: calc(210rpx + env(safe-area-inset-bottom));
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(123, 92, 175, 0.28);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 25;
}
.ld-backtop-ico {
  width: 34rpx;
  height: 34rpx;
}
.ld-backtop-label {
  font-size: 18rpx;
  color: var(--ld-purple-meta);
}

/* 轻提示 toast */
.ld-toast {
  position: fixed;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%) scale(0.9);
  max-width: 70%;
  padding: 26rpx 38rpx;
  background: rgba(0, 0, 0, 0.82);
  color: #fff;
  font-size: 26rpx;
  border-radius: 22rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s, transform 0.2s;
  z-index: 60;
}
.ld-toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

/* ---------- ⑩ 定格动画测试版（特写位换舞台·测试分支） ---------- */
/* 帧叠层：36 帧全常驻渲染树，opacity 切换（唯一写者 = stopmotion.wxs）。
   will-change: opacity = Blink 源码级「隐藏帧解码/光栅缓存保温」开关（不绘制的帧缓存会被内核回收、
   切到冷帧重解码掉帧；裸 opacity:0 与 hidden 同样不保温）——安卓 XWeb 线有源码依据，iOS 无对应
   保证、靠入场扫帧预热兜底（真机 A/B 项，见 2026-07-18 批记账）。 */
.sm-frame {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  will-change: opacity;
}
/* 高清定格层（1080²·静止时压顶保清晰）：拖动瞬间被 wxs 撤下（同帧同画面无跳变），归位后淡入 */
.sm-hi {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  opacity: 1;
  transition: opacity 0.18s ease;
}
.sm-chip {
  position: absolute;
  z-index: 3;
  top: 18rpx;
  left: 18rpx;
  padding: 8rpx 18rpx;
  border-radius: var(--ld-radius-pill);
  background: rgba(255, 255, 255, 0.78);
  color: #6b5a8a;
  font-size: 22rpx;
}
.sm-hint-chip {
  position: absolute;
  z-index: 3;
  bottom: 96rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 10rpx 24rpx;
  border-radius: var(--ld-radius-pill);
  background: rgba(58, 47, 74, 0.62);
  color: #fff;
  font-size: 24rpx;
  white-space: nowrap;
}
/* 凹槽滑轨（触摸面·拟物样式承 flip-demo 方案一真机验证版）：stage 不吃触摸，滚动无死区 */
.sm-rail {
  position: relative;
  height: 90rpx;
  width: 80%;
  margin: 20rpx auto 0;
}
.sm-groove {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 50%;
  height: 30rpx;
  margin-top: -15rpx;
  border-radius: var(--ld-radius-pill);
  background: linear-gradient(180deg, #e4e2da, #f0efe9 75%);
  box-shadow: inset 0 3rpx 7rpx rgba(54, 58, 80, 0.16), inset 0 -2rpx 0 rgba(255, 255, 255, 0.8);
}
.sm-groove::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 15rpx;
  margin: -7rpx 0 0 -2rpx;
  border-radius: 2rpx;
  background: rgba(54, 58, 80, 0.22);
}
.sm-fader {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 86rpx;
  height: 60rpx;
  margin: -30rpx 0 0 -43rpx; /* 居中锚点·位移全走 transform（wxs 写 px） */
  border-radius: var(--ld-radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(180deg, #ffffff, #f2f0ea);
  box-shadow: 0 3rpx 6rpx rgba(54, 58, 80, 0.16), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}
.sm-fader-on {
  box-shadow: 0 4rpx 7rpx rgba(54, 58, 80, 0.2), 0 2rpx 2rpx rgba(54, 58, 80, 0.14),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9), inset 0 -2rpx 2rpx rgba(0, 0, 0, 0.06);
}
.sm-fader-bar {
  width: 6rpx;
  height: 22rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #dad8d0, #e9e7e0);
  box-shadow: inset 0 2rpx 2rpx rgba(0, 0, 0, 0.1), 0 2rpx 0 rgba(255, 255, 255, 0.85);
}
