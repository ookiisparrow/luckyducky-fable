.ld-me {
  min-height: 100vh;
  background: var(--ld-bg-lilac);
  padding: 48rpx 24rpx;
}
.ld-me-head {
  padding: 24rpx 8rpx 40rpx;
}
.ld-me-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
}
.ld-me-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
.ld-me-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
  background: var(--ld-bg);
  border-radius: var(--ld-radius);
  border: 2rpx solid var(--ld-purple-line);
  font-size: 28rpx;
  color: var(--ld-ink);
}
.ld-me-arrow {
  color: var(--ld-purple-meta);
  font-size: 32rpx;
}
