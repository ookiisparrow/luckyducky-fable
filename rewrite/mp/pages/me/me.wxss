.ld-stub {
  min-height: 100vh;
  background: var(--ld-bg-lilac);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.ld-stub-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
}
.ld-stub-hint {
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
