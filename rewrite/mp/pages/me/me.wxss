.ld-me {
  min-height: 100vh;
  background: var(--ld-bg-lilac);
  padding: 32rpx 24rpx 200rpx;
}
.ld-me-profile {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  background: var(--ld-bg);
  border-radius: var(--ld-radius);
  border: 2rpx solid var(--ld-purple-line);
}
.ld-me-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: var(--ld-bg-sage);
  flex-shrink: 0;
}
.ld-me-avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}
.ld-me-info {
  flex: 1;
  min-width: 0;
}
.ld-me-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
}
.ld-me-bio {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ld-me-continue {
  padding: 30rpx 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(160deg, #f3e9ff 0%, var(--ld-bg) 90%);
  border-radius: var(--ld-radius);
  border: 2rpx solid var(--ld-purple-line);
}
.ld-me-ct-label {
  font-size: 22rpx;
  color: var(--ld-purple-tab);
  letter-spacing: 2rpx;
}
.ld-me-ct-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ld-purple-ink);
}
.ld-me-ct-lesson {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
.ld-me-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
  background: var(--ld-bg);
  border-radius: var(--ld-radius);
  border: 2rpx solid var(--ld-purple-line);
  font-size: 28rpx;
  color: var(--ld-ink);
}
.ld-me-arrow {
  color: var(--ld-purple-meta);
  font-size: 32rpx;
}
