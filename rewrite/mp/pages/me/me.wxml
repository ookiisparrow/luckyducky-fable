<view class="ld-me">
  <!-- 头部·大字问候（editorial）：品牌 logo + 欢迎回来大字 + 安静的编辑链接 -->
  <view class="ld-me-header">
    <view class="ld-me-brandrow">
      <image class="ld-me-logo" src="/static/logo-wordmark.svg" mode="heightFix" />
    </view>
    <view class="ld-me-greet">
      <view class="ld-me-greet-text">
        <view class="ld-me-eyebrow">欢迎回来</view>
        <view class="ld-me-greet-name">{{nickname}}</view>
        <view wx:if="{{bio}}" class="ld-me-greet-bio">{{bio}}</view>
      </view>
      <image wx:if="{{avatar}}" class="ld-me-avatar" src="{{avatar}}" mode="aspectFill" />
      <view wx:else class="ld-me-avatar ld-me-avatar-empty">🦆</view>
    </view>
    <view class="ld-me-edit" bind:tap="onEditProfile" hover-class="ld-me-edit-h">
      <text>编辑资料</text>
    </view>
  </view>

  <view class="ld-me-stack">
    <!-- 继续学习 / 学习记录 -->
    <view class="ld-me-card ld-me-card-pad">
      <view class="ld-me-sec-head">
        <view class="ld-me-sec-title">
          <image class="ld-me-sec-ico" src="/static/icons/graduation-cap.svg" mode="aspectFit" />
          <text>{{cont ? '继续学习' : '学习记录'}}</text>
        </view>
        <view wx:if="{{cont && entries.courses.visible}}" class="ld-me-sec-more" bind:tap="onCourses">
          <text>{{entries.courses.label}}</text>
          <image class="ld-me-sec-more-ico" src="/static/icons/chevron-right.svg" mode="aspectFit" />
        </view>
      </view>

      <block wx:if="{{cont}}">
        <view class="ld-me-video" bind:tap="onContinue" hover-class="ld-me-video-h">
          <view class="ld-me-play">
            <image class="ld-me-play-ico" src="/static/icons/play.svg" mode="aspectFit" />
          </view>
          <view class="ld-me-video-cap">
            <view class="ld-me-video-ep">{{cont.courseTitle}}</view>
            <view class="ld-me-video-name">{{cont.lessonName}}</view>
          </view>
        </view>
        <view class="ld-me-resume">
          <view class="ld-me-resume-btn" bind:tap="onContinue" hover-class="ld-me-resume-btn-h">
            <text>继续观看</text>
          </view>
        </view>
      </block>

      <!-- 取数失败态（同 aftersales/order-list loadFailed 分治）：失败≠没进度，不显「还没有学习记录」假空态 -->
      <view wx:elif="{{contFailed}}" class="ld-me-empty">
        <view class="ld-me-empty-ico">
          <image class="ld-me-empty-img" src="/static/icons/play-circle.svg" mode="aspectFit" />
        </view>
        <view class="ld-me-empty-title">没连上网络</view>
        <view class="ld-me-empty-sub">学习记录暂时没拉下来，检查网络后再试一次。</view>
        <view class="ld-me-resume-btn" bind:tap="onRetryCont" hover-class="ld-me-resume-btn-h">
          <text>重新加载</text>
        </view>
      </view>

      <!-- 空态只在「首次取数已落地(contLoaded)且真无课」时出现——避免加载中 cont=null 就渲染假空态（先空后有闪烁·2026-07-13 反馈） -->
      <view wx:elif="{{contLoaded}}" class="ld-me-empty">
        <view class="ld-me-empty-ico">
          <image class="ld-me-empty-img" src="/static/icons/play-circle.svg" mode="aspectFit" />
        </view>
        <view class="ld-me-empty-title">还没有学习记录</view>
        <view class="ld-me-empty-sub">看过的钩织教程会出现在这里。先挑一只喜欢的小棉鸭，开箱就能跟着视频一步步钩。</view>
        <view class="ld-me-resume-btn" bind:tap="onContinue" hover-class="ld-me-resume-btn-h">
          <text>去首页挑套装</text>
        </view>
      </view>

      <!-- 加载中骨架（首次 refresh 未落地·contLoaded 前）：占位不放任何「暂无/没有」文案，切真卡零高度跳变 -->
      <view wx:else class="ld-me-cont-skeleton">
        <view class="ld-me-cont-skeleton-video"></view>
        <view class="ld-me-cont-skeleton-btn"></view>
      </view>
    </view>

    <!-- 我的订单四格 -->
    <view class="ld-me-card ld-me-card-pad">
      <view class="ld-me-sec-head">
        <view class="ld-me-sec-title"><text>我的订单</text></view>
        <view wx:if="{{entries.orders.visible}}" class="ld-me-sec-more" bind:tap="onOrders">
          <text>{{entries.orders.label}}</text>
          <image class="ld-me-sec-more-ico" src="/static/icons/chevron-right.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="ld-me-orders">
        <view class="ld-me-order" data-tab="pending" bind:tap="onOrders" hover-class="ld-me-order-h">
          <view class="ld-me-order-ico"><image class="ld-me-order-img" src="/static/icons/wallet.svg" mode="aspectFit" /></view>
          <text class="ld-me-order-label">待付款</text>
        </view>
        <view class="ld-me-order" data-tab="paid" bind:tap="onOrders" hover-class="ld-me-order-h">
          <view class="ld-me-order-ico"><image class="ld-me-order-img" src="/static/icons/package.svg" mode="aspectFit" /></view>
          <text class="ld-me-order-label">待发货</text>
        </view>
        <view class="ld-me-order" data-tab="shipped" bind:tap="onOrders" hover-class="ld-me-order-h">
          <view class="ld-me-order-ico"><image class="ld-me-order-img" src="/static/icons/truck.svg" mode="aspectFit" /></view>
          <text class="ld-me-order-label">待收货</text>
        </view>
        <view wx:if="{{entries.aftersales.visible}}" class="ld-me-order" bind:tap="onAfterSales" hover-class="ld-me-order-h">
          <view class="ld-me-order-ico"><image class="ld-me-order-img" src="/static/icons/rotate-ccw.svg" mode="aspectFit" /></view>
          <text class="ld-me-order-label">{{entries.aftersales.label}}</text>
        </view>
      </view>
    </view>

    <!-- 常用入口列 -->
    <view class="ld-me-card ld-me-list">
      <view wx:if="{{entries.address.visible}}" class="ld-me-row" bind:tap="onAddress" hover-class="ld-me-row-h">
        <view class="ld-me-row-ico"><image class="ld-me-row-img" src="/static/icons/map-pin.svg" mode="aspectFit" /></view>
        <text class="ld-me-row-label">{{entries.address.label}}</text>
        <image class="ld-me-row-chev" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{entries.activate.visible}}" class="ld-me-row" bind:tap="onActivate" hover-class="ld-me-row-h">
        <view class="ld-me-row-ico"><image class="ld-me-row-img" src="/static/icons/ticket.svg" mode="aspectFit" /></view>
        <text class="ld-me-row-label">{{entries.activate.label}}</text>
        <image class="ld-me-row-chev" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{entries.feedback.visible}}" class="ld-me-row" bind:tap="onFeedback" hover-class="ld-me-row-h">
        <view class="ld-me-row-ico"><image class="ld-me-row-img" src="/static/icons/message-circle.svg" mode="aspectFit" /></view>
        <text class="ld-me-row-label">{{entries.feedback.label}}</text>
        <image class="ld-me-row-chev" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{entries.kefu.visible}}" class="ld-me-row" bind:tap="onKefu" hover-class="ld-me-row-h">
        <view class="ld-me-row-ico"><image class="ld-me-row-img" src="/static/icons/headphones.svg" mode="aspectFit" /></view>
        <text class="ld-me-row-label">{{entries.kefu.label}}</text>
        <image class="ld-me-row-chev" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{entries.consent.visible}}" class="ld-me-row" bind:tap="onConsent" hover-class="ld-me-row-h">
        <view class="ld-me-row-ico"><image class="ld-me-row-img" src="/static/icons/shield-check.svg" mode="aspectFit" /></view>
        <text class="ld-me-row-label">{{entries.consent.label}}</text>
        <image class="ld-me-row-chev" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{entries.about.visible}}" class="ld-me-row" bind:tap="onAbout" hover-class="ld-me-row-h">
        <view class="ld-me-row-ico"><image class="ld-me-row-img" src="/static/icons/info.svg" mode="aspectFit" /></view>
        <text class="ld-me-row-label">{{entries.about.label}}</text>
        <image class="ld-me-row-chev" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <view class="ld-me-pad-bottom"></view>
</view>
