<!-- 评价晒单·重设计对齐 Checkout.jsx ReviewSubmit（corev-* 版式·设计 402px→rpx ×1.87）。
     业务逻辑承接 review.ts：星级(onStar)/标签多选(onTag)/文字(onText)/匿名(onAnon)/提交(onSubmit·busy 闸)。
     买家秀晒图：选图传云存储 cloud://（picker 直接 <image src=cloud://> 显缩略），内容安全在云端提交时逐张校（fail-closed）。 -->
<view class="corev">
  <view class="corev-body">

    <!-- 商品行 + 综合评分（corev-top 卡） -->
    <view class="corev-card corev-top">
      <view class="corev-prod" wx:if="{{name}}">
        <view class="corev-prod-img"></view>
        <view class="corev-prod-mid">
          <text class="corev-prod-name">{{name}}</text>
        </view>
      </view>
      <view class="corev-rate">
        <view class="corev-rate-stars">
          <text
            wx:for="{{starIdx}}"
            wx:key="*this"
            class="corev-star {{rating >= item ? 'on' : ''}}"
            data-n="{{item}}"
            bind:tap="onStar"
          >★</text>
        </view>
        <text class="corev-rate-label">{{ratingLabel}}</text>
      </view>
    </view>

    <!-- 大家都说·预设标签多选（corev-sec 卡） -->
    <view class="corev-card corev-sec">
      <view class="corev-sec-title">大家都说</view>
      <view class="corev-tags">
        <text
          wx:for="{{tags}}"
          wx:key="t"
          class="corev-tag {{item.on ? 'on' : ''}}"
          data-i="{{index}}"
          bind:tap="onTag"
        >{{item.t}}</text>
      </view>
    </view>

    <!-- 文字（corev-sec 卡） -->
    <view class="corev-card corev-sec">
      <textarea
        class="corev-text"
        value="{{text}}"
        bind:input="onText"
        maxlength="500"
        placeholder="说说你的钩织体验，分享给想入坑的小伙伴吧～"
        placeholder-class="corev-text-ph"
      />
      <view class="corev-count">{{text.length}}/500</view>
    </view>

    <!-- 买家秀晒图（corev-sec 卡·选图传云存储·内容安全云端逐张校） -->
    <view class="corev-card corev-sec">
      <view class="corev-sec-title">晒图（选填·最多 {{maxPhotos}} 张）</view>
      <view class="corev-photos">
        <view class="corev-photo" wx:for="{{photos}}" wx:key="*this">
          <image class="corev-photo-img" src="{{item}}" mode="aspectFill" data-url="{{item}}" bind:tap="onPreviewPhoto" />
          <view class="corev-photo-del" data-i="{{index}}" catch:tap="onDelPhoto">
            <image class="corev-photo-del-ico" src="/static/icons/x.svg" mode="aspectFit" />
          </view>
        </view>
        <view class="corev-photo-add" wx:if="{{photos.length < maxPhotos}}" bind:tap="onAddPhotos">
          <block wx:if="{{uploading}}">
            <view class="corev-photo-spin"></view>
          </block>
          <block wx:else>
            <image class="corev-photo-add-ico" src="/static/icons/camera-add.svg" mode="aspectFit" />
            <text class="corev-photo-add-txt">添加</text>
          </block>
        </view>
      </view>
    </view>

    <!-- 匿名开关（corev-anon 卡） -->
    <view class="corev-card corev-anon {{anon ? 'on' : ''}}" bind:tap="onAnon">
      <text class="corev-anon-text">匿名评价</text>
      <text class="corev-anon-sub">隐藏你的昵称与头像</text>
      <view class="corev-switch">
        <view class="corev-switch-dot"></view>
      </view>
    </view>

  </view>

  <!-- 底部发布坞 -->
  <view class="corev-dock-space"></view>
  <view class="corev-dock">
    <view class="corev-dockbar">
      <view class="corev-publish {{busy ? 'dim' : ''}}" bind:tap="onSubmit">发布评价</view>
    </view>
  </view>

  <!-- 隐私授权弹窗（晒图走 wx.chooseMedia 属隐私接口·守卫 rw-mp-privacy-gated） -->
  <privacy-sheet />
</view>
