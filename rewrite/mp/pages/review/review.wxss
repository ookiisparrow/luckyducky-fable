.ld-review {
  min-height: 100vh;
  background: var(--ld-bg-lilac);
  padding: 24rpx;
}
.ld-panel {
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: var(--ld-bg);
  border-radius: var(--ld-radius);
  border: 2rpx solid var(--ld-purple-line);
}
.ld-rw-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ld-ink);
  margin-bottom: 16rpx;
}
.ld-rw-stars {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.ld-rw-star {
  font-size: 56rpx;
  color: var(--ld-purple-line);
}
.ld-rw-star.on {
  color: var(--ld-purple);
}
.ld-rw-starlabel {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
.ld-rw-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.ld-rw-tag {
  padding: 10rpx 26rpx;
  border-radius: var(--ld-radius-pill);
  border: 2rpx solid var(--ld-purple-line);
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
.ld-rw-tag.on {
  background: var(--ld-bg-lilac);
  border-color: var(--ld-purple-tab);
  color: var(--ld-purple-tab);
  font-weight: 600;
}
.ld-rw-text {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: var(--ld-bg-faint);
  border-radius: 16rpx;
  font-size: 26rpx;
}
.ld-rw-anon {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--ld-purple-meta);
}
.ld-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid var(--ld-purple-line);
}
.ld-check.on {
  background: var(--ld-purple-tab);
  border-color: var(--ld-purple-tab);
}
.ld-rw-submit {
  text-align: center;
  padding: 26rpx 0;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple-ink);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
.ld-rw-submit.dim {
  opacity: 0.5;
}
