<!-- 课程播放页·竖屏沉浸全屏重设计（M2 批：一键投屏 + 帮助入口）。
     整页纯黑铺满（player.json navigationStyle:custom）；视频 1:1.68（宽:高）居中，
     上下 UI 是黑条覆盖层（普通 view 绝对定位 z-index 盖在 video 上·同层渲染官方已允许，不必 cover-view）。
     业务逻辑与既有回归红线（playToken 乱序防护/首帧埋点/segment_done/watch_at/25min 地址缓存）一字不动，
     本文件只重排结构与视觉 + 新增投屏/进度条/帮助。 -->
<view class="ld-player">

  <!-- 顶条：返回 + 当前段落标题（避让状态栏；右上刻意留白——原生投屏按钮渲染在视频区右上角，勿遮挡） -->
  <view class="lp-topbar" style="padding-top: {{statusBarHeight}}px">
    <view class="lp-back" bind:tap="onBack">
      <image class="lp-back-ico" src="/static/icons/chevron-right.svg" mode="aspectFit" />
    </view>
    <view class="lp-topbar-title">{{current.lessonName || title || '正在学习'}}</view>
  </view>

  <!-- 视频舞台（1:1.68·padding-top 百分比法·避 aspect-ratio·旧 WebView 不支持·垂直居中） -->
  <view class="lp-stage">
    <block wx:if="{{state === 'playing' || state === 'loading'}}">
      <view class="lp-video-box">
        <video
          wx:if="{{src}}"
          id="lp-video"
          class="lp-video"
          src="{{src}}"
          autoplay
          controls="{{false}}"
          show-casting-button="{{true}}"
          bind:play="onVideoPlay"
          bind:pause="onVideoPause"
          bind:ended="onEnded"
          bind:error="onVideoError"
          bind:timeupdate="onTimeUpdate"
          bind:castinguserselect="onCastingUserSelect"
          bind:castingstatechange="onCastingStateChange"
          bind:castinginterrupt="onCastingInterrupt"
        ></video>
        <view wx:else class="lp-video lp-skeleton">
          <view class="lp-skeleton-spin"></view>
          <view class="lp-skeleton-text">正在加载首帧…</view>
        </view>

        <!-- 全屏单击播放/暂停（透明点击层·playing 才挂·paused 以 bind:play/bind:pause 回报为准）；
             暂停指示图标是它的子节点（非按钮·点它也走冒泡命中父层 tapzone·整屏单击即恢复）。 -->
        <view wx:if="{{src}}" class="lp-tapzone" bind:tap="onTapVideo">
          <view wx:if="{{paused}}" class="lp-pause-badge">
            <image class="lp-pause-ico" src="/static/icons/play-circle.svg" mode="aspectFit" />
          </view>
        </view>
      </view>
    </block>

    <view class="lp-video-box lp-state" wx:elif="{{state === 'empty'}}">
      <view class="lp-state-title">这段视频还在整理中</view>
      <view class="lp-state-hint">先看看别的段落吧</view>
    </view>
    <view class="lp-video-box lp-state" wx:elif="{{state === 'denied'}}">
      <view class="lp-state-title">先激活课程才能观看</view>
      <view class="lp-state-btn" bind:tap="onGoActivate">去输入激活码</view>
    </view>
    <view class="lp-video-box lp-state" wx:elif="{{state === 'missing'}}">
      <view class="lp-state-title">课程不存在</view>
    </view>
    <view class="lp-video-box lp-state" wx:elif="{{state === 'error'}}">
      <view class="lp-state-title">这段视频暂时播放不了</view>
      <view class="lp-state-hint">可能是网络或格式问题，换一段或稍后再试</view>
      <view class="lp-state-actions">
        <view class="lp-state-btn" bind:tap="onRetryError">重试本段</view>
        <view class="lp-state-btn ghost" bind:tap="onToggleList">选其他段</view>
      </view>
    </view>
  </view>

  <!-- 底条：仅播放中显示——第一行进度(时间+slider+时长)，第二行 帮助|上一段|目录|下一段|投屏 -->
  <view class="lp-bottombar" wx:if="{{state === 'playing'}}">
    <view class="lp-progress-row">
      <text class="lp-time">{{curClock}}</text>
      <slider
        class="lp-slider"
        min="0"
        max="{{durSec || 1}}"
        value="{{curSec}}"
        block-size="12"
        activeColor="#f9bf63"
        backgroundColor="rgba(255,255,255,0.28)"
        bind:changing="onSliderChanging"
        bind:change="onSliderChange"
      />
      <text class="lp-time">{{durClock}}</text>
    </view>

    <view class="lp-controls">
      <view class="lp-ctl" bind:tap="onHelp">帮助</view>
      <view class="lp-ctl {{canPrev ? '' : 'dim'}}" bind:tap="onPrev">上一段</view>
      <view class="lp-ctl solid {{listOpen ? 'on' : ''}}" bind:tap="onToggleList">目录</view>
      <view class="lp-ctl {{canNext ? '' : 'dim'}}" bind:tap="onNext">下一段</view>
      <view class="lp-ctl" bind:tap="onCast">投屏</view>
    </view>
  </view>

  <!-- 段落目录：底部抽屉浮层（半透明遮罩 + catchtouchmove 锁滚动 + 点遮罩关闭） -->
  <view class="lp-drawer-mask" wx:if="{{listOpen}}" bind:tap="onToggleList" catchtouchmove="noop"></view>
  <view class="lp-drawer {{listOpen ? 'open' : ''}}" catchtouchmove="noop">
    <view class="lp-drawer-handle"></view>
    <scroll-view class="lp-drawer-scroll" scroll-y="{{true}}">
      <view
        class="lp-seg {{item.segmentId === current.segmentId ? 'on' : ''}} {{item.hasVideo ? '' : 'off'}}"
        wx:for="{{segments}}"
        wx:key="segmentId"
        data-id="{{item.segmentId}}"
        bind:tap="onPickSegment"
      >
        <view class="lp-seg-ico">
          <view class="lp-eq" wx:if="{{item.segmentId === current.segmentId && state === 'playing' && !paused}}">
            <view class="lp-eq-bar"></view>
            <view class="lp-eq-bar"></view>
            <view class="lp-eq-bar"></view>
          </view>
          <view class="lp-seg-play" wx:elif="{{item.hasVideo}}">
            <image class="lp-seg-play-img" src="/static/icons/play.svg" mode="aspectFit" />
          </view>
          <view class="lp-seg-dot" wx:else></view>
        </view>
        <view class="lp-seg-mid">
          <view class="lp-seg-name">{{item.lessonName || '本节'}}</view>
          <view class="lp-seg-sub">{{item.segName || '片段'}}</view>
        </view>
        <text class="lp-seg-flag" wx:if="{{!item.hasVideo}}">整理中</text>
        <text class="lp-seg-flag hot" wx:elif="{{item.segmentId === current.segmentId}}">播放中</text>
      </view>
    </scroll-view>
  </view>
</view>
