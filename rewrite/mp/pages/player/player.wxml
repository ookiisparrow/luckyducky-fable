<!-- 课程播放页·竖屏沉浸全屏重设计（播放器重设计战役 批B：P1 常态结构重排 + P4 段落播完不自动切换）。
     整页纯黑铺满（player.json navigationStyle:custom）；视频 1:1.68（宽:高）居中，
     上下 UI 是黑条覆盖层（普通 view 绝对定位 z-index 盖在 video 上·同层渲染官方已允许，不必 cover-view）。
     业务逻辑与既有回归红线（playToken 乱序防护/首帧埋点/segment_done/watch_at/25min 地址缓存）一字不动；
     唯一刻意行为变更＝段落播完不再自动切下一段（onEnded 停在完成态，重播/切段交由用户，见 player.ts）。
     P2 拖动态（自绘 seek/节点磁吸/震感）、P3 求助面板是后续批：本批保留原生 <slider>，求助钮仍直连客服。 -->
<view class="ld-player">

  <!-- 顶条：返回 + 两行标题（数据源=批A lib/player 的 lessonStrip：主行 chapterTitle/副行 lessonNo·lessonName，
       chapterTitle 空则只显 lessonName 脏档回退）+ 右侧留白 spacer（真机右上是原生胶囊+原生投屏按钮，
       继续保持右上留白纪律，不放任何自绘元素） -->
  <view class="lp-topbar" style="padding-top: {{statusBarHeight}}px">
    <view class="lp-back" bind:tap="onBack">
      <image class="lp-back-ico" src="/static/icons/chevron-right.svg" mode="aspectFit" />
    </view>
    <view class="lp-topbar-title">
      <block wx:if="{{strip && strip.chapterTitle}}">
        <view class="lp-title-main">{{strip.chapterTitle}}</view>
        <view class="lp-title-sub">{{strip.lessonNo}} · {{strip.lessonName}}</view>
      </block>
      <view class="lp-title-main" wx:else>{{(strip && strip.lessonName) || title || '正在学习'}}</view>
    </view>
    <view class="lp-topbar-spacer"></view>
  </view>

  <!-- 视频舞台（1:1.68·padding-top 百分比法·避 aspect-ratio·旧 WebView 不支持·垂直居中） -->
  <view class="lp-stage">
    <block wx:if="{{state === 'playing' || state === 'loading'}}">
      <view class="lp-video-box">
        <video
          wx:if="{{src}}"
          id="lp-video"
          class="lp-video"
          src="{{src}}"
          autoplay
          controls="{{false}}"
          show-casting-button="{{true}}"
          bind:play="onVideoPlay"
          bind:pause="onVideoPause"
          bind:ended="onEnded"
          bind:error="onVideoError"
          bind:timeupdate="onTimeUpdate"
          bind:castinguserselect="onCastingUserSelect"
          bind:castingstatechange="onCastingStateChange"
          bind:castinginterrupt="onCastingInterrupt"
        ></video>
        <view wx:else class="lp-video lp-skeleton">
          <view class="lp-skeleton-spin"></view>
          <view class="lp-skeleton-text">正在加载首帧…</view>
        </view>

        <!-- 全屏单击播放/暂停（透明点击层·playing 才挂·paused 以 bind:play/bind:pause 回报为准）；
             暂停指示图标是它的子节点（非按钮·点它也走冒泡命中父层 tapzone·整屏单击即恢复）。 -->
        <view wx:if="{{src}}" class="lp-tapzone" bind:tap="onTapVideo">
          <view wx:if="{{paused}}" class="lp-pause-badge">
            <image class="lp-pause-ico" src="/static/icons/play-circle.svg" mode="aspectFit" />
          </view>
        </view>
      </view>

      <!-- 单击提示条：仅播放中且未被首次 tap 关闭过（页面实例级·不持久化） -->
      <view class="lp-tap-hint" wx:if="{{state === 'playing' && src && !hintDismissed}}">单击画面 播放 / 暂停</view>

      <!-- 分段进度条浮层：段落层级只活在这里（目录页只到课时层，批D 再落） -->
      <view class="lp-segstrip" wx:if="{{strip}}">
        <view class="lp-segs">
          <view class="lp-seg-cell {{item}}" wx:for="{{strip.cells}}" wx:key="*this"></view>
        </view>
        <view class="lp-segcap">
          <text class="lp-segcap-text">{{capText}}</text>
          <view class="lp-legend" wx:if="{{current && current.marks && current.marks.length > 0}}">
            <text class="lp-legend-dot">◆</text>
            <text class="lp-legend-text">关键动作节点</text>
          </view>
        </view>
      </view>
    </block>

    <view class="lp-video-box lp-state" wx:elif="{{state === 'empty'}}">
      <view class="lp-state-title">这段视频还在整理中</view>
      <view class="lp-state-hint">先看看别的段落吧</view>
      <view class="lp-state-actions">
        <view class="lp-state-btn ghost" wx:if="{{canNext}}" bind:tap="onNext">跳到下一段</view>
      </view>
    </view>
    <view class="lp-video-box lp-state" wx:elif="{{state === 'denied'}}">
      <view class="lp-state-title">先激活课程才能观看</view>
      <view class="lp-state-btn" bind:tap="onGoActivate">去输入激活码</view>
    </view>
    <view class="lp-video-box lp-state" wx:elif="{{state === 'missing'}}">
      <view class="lp-state-title">课程不存在</view>
    </view>
    <view class="lp-video-box lp-state" wx:elif="{{state === 'error'}}">
      <view class="lp-state-title">这段视频暂时播放不了</view>
      <view class="lp-state-hint">可能是网络或格式问题，换一段或稍后再试</view>
      <view class="lp-state-actions">
        <view class="lp-state-btn" bind:tap="onRetryError">重试本段</view>
        <view class="lp-state-btn ghost" wx:if="{{canNext}}" bind:tap="onNext">跳到下一段</view>
      </view>
    </view>
  </view>

  <!-- 底条：仅播放中显示——段落播完(segDone) 顶部通栏重播长条 + 进度(时间+slider+时长) + 求助|上一段|下一段 -->
  <view class="lp-bottombar" wx:if="{{state === 'playing'}}">
    <view class="lp-replay" wx:if="{{segDone}}" bind:tap="onReplay">
      <image class="lp-replay-ico" src="/static/icons/rotate-ccw.svg" mode="aspectFit" />
      <text>重播本段</text>
    </view>

    <view class="lp-progress-row">
      <text class="lp-time">{{curClock}}</text>
      <slider
        class="lp-slider"
        min="0"
        max="{{durSec || 1}}"
        value="{{curSec}}"
        block-size="28"
        activeColor="#a371ea"
        backgroundColor="rgba(255,255,255,0.24)"
        bind:changing="onSliderChanging"
        bind:change="onSliderChange"
      />
      <text class="lp-time">{{durClock}}</text>
    </view>

    <view class="lp-controls">
      <view class="lp-chev {{canPrev ? '' : 'dim'}}" bind:tap="onPrev">
        <image class="lp-chev-ico lp-chev-prev" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
      <view class="lp-helpbtn" bind:tap="onHelp">
        <image class="lp-helpbtn-ico" src="/static/icons/headset.svg" mode="aspectFit" />
      </view>
      <view class="lp-chev {{canNext ? '' : 'dim'}}" bind:tap="onNext">
        <image class="lp-chev-ico" src="/static/icons/chevron-right.svg" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>
