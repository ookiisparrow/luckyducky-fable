/* 定格动画（三档拨杆）隔离验证页。设计稿 402px 画板 → rpx（750/402≈1.87 换算·保比例，同 home）。
   fd- 前缀避免与正式页样式冲突；拨杆几何承设计稿 .ld-flip-rail-e 族。 */
.fd-page {
  min-height: 100vh;
  padding: 30rpx 37rpx 80rpx;
  box-sizing: border-box;
  background: var(--ld-bg);
}

.fd-head {
  margin-bottom: 26rpx;
}
.fd-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--ld-ink);
}
.fd-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--ld-content-2);
}

/* ---------- 画面舞台：方形（padding-top 百分比法·避 aspect-ratio 旧 WebView 不支持） ---------- */
.fd-stage {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: var(--ld-radius-md);
  overflow: hidden;
  background: var(--ld-bg-sage);
}
.fd-cell {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}
.fd-num {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 157rpx; /* 设计 84px */
  color: rgba(34, 34, 34, 0.13);
  letter-spacing: 0.02em;
}
.fd-dot {
  position: absolute;
  width: 37rpx; /* 设计 20px */
  height: 37rpx;
  border-radius: 50%;
  background: var(--ld-duck);
  box-shadow: 0 6rpx 15rpx rgba(226, 150, 30, 0.35);
  transform: translate(-50%, -50%);
}
.fd-tag {
  position: absolute;
  left: 22rpx;
  bottom: 19rpx;
  font-size: 19rpx; /* 设计 10px */
  letter-spacing: 0.12em;
  color: rgba(34, 34, 34, 0.45);
}
.fd-counter {
  position: absolute;
  top: 19rpx;
  right: 22rpx;
  font-size: 21rpx; /* 设计 11px */
  letter-spacing: 0.06em;
  color: var(--ld-ink);
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  padding: 6rpx 15rpx;
  border-radius: var(--ld-radius-pill);
}

/* ---------- 滑轨公共（两方案均：宽 80% 居中） ---------- */
.fd-rail {
  position: relative;
  height: 97rpx;
  width: 80%;
  margin: 26rpx auto 0;
}
.fd-sec-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ld-content);
  margin: 0 0 14rpx;
}
.fd-sec-gap {
  margin-top: 60rpx; /* 设计 .ld-flip + .ld-flip 间距 24px，另加分组标题呼吸感 */
}

/* ---------- 方案一 · 拟物凹槽（设计 .ld-flip-rail-d：高 48px·内凹滑槽+立体推钮） ---------- */
.fd-rail-jog {
  height: 90rpx;
}
.fd-groove {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 50%;
  height: 30rpx; /* 设计 16px */
  margin-top: -15rpx;
  border-radius: var(--ld-radius-pill);
  background: linear-gradient(180deg, #e4e2da, #f0efe9 75%);
  box-shadow: inset 0 4rpx 9rpx rgba(54, 58, 80, 0.22), inset 0 -2rpx 0 rgba(255, 255, 255, 0.85),
    inset 0 0 0 1rpx rgba(0, 0, 0, 0.05);
}
.fd-groove::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx; /* 设计 2px 中位刻度 */
  height: 15rpx;
  margin: -7rpx 0 0 -2rpx;
  border-radius: 2rpx;
  background: rgba(54, 58, 80, 0.2);
}
.fd-fader {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 86rpx; /* 设计 46px */
  height: 60rpx; /* 设计 32px */
  margin: -30rpx 0 0 -43rpx; /* 居中锚点·位移全走 transform（JS px） */
  border-radius: var(--ld-radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 6rpx 13rpx rgba(54, 58, 80, 0.22), 0 2rpx 4rpx rgba(54, 58, 80, 0.14),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9), inset 0 -2rpx 2rpx rgba(0, 0, 0, 0.06);
}
.fd-rail-jog.dragging .fd-fader {
  box-shadow: 0 4rpx 7rpx rgba(54, 58, 80, 0.2), 0 2rpx 2rpx rgba(54, 58, 80, 0.14),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9), inset 0 -2rpx 2rpx rgba(0, 0, 0, 0.06);
}
.fd-fader-bar {
  width: 6rpx; /* 设计 3px */
  height: 22rpx; /* 设计 12px */
  border-radius: 4rpx;
  background: linear-gradient(180deg, #dad8d0, #e9e7e0);
  box-shadow: inset 0 2rpx 2rpx rgba(0, 0, 0, 0.1), 0 2rpx 0 rgba(255, 255, 255, 0.85);
}

/* ---------- 方案二 · 三档拨杆（设计 .ld-flip-rail-e：高 52px） ---------- */
.fd-rail-lever {
  height: 97rpx;
}
.fd-slot {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 50%;
  height: 19rpx; /* 设计 10px */
  margin-top: -10rpx;
  border-radius: var(--ld-radius-pill);
  background: linear-gradient(180deg, #e4e2da, #f0efe9 75%);
  box-shadow: inset 0 4rpx 7rpx rgba(54, 58, 80, 0.2), inset 0 -2rpx 0 rgba(255, 255, 255, 0.85),
    inset 0 0 0 1rpx rgba(0, 0, 0, 0.05);
}
.fd-detents {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 50%;
  height: 0;
}
.fd-detent {
  position: absolute;
  top: -4rpx;
  width: 7rpx; /* 设计 4px */
  height: 7rpx;
  border-radius: 50%;
  background: rgba(54, 58, 80, 0.28);
}
.fd-detent-l {
  left: 24rpx; /* 设计 13px */
}
.fd-detent-c {
  left: 50%;
  margin-left: -4rpx;
}
.fd-detent-r {
  right: 24rpx;
}
.fd-lever {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 56rpx; /* 设计 30px */
  height: 82rpx; /* 设计 44px */
  margin: -41rpx 0 0 -28rpx; /* 居中锚点·位移全走 transform（JS px） */
  border-radius: 17rpx; /* 设计 9px */
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 7rpx 19rpx rgba(54, 58, 80, 0.2), inset 0 2rpx 0 rgba(255, 255, 255, 0.9),
    inset 0 -2rpx 2rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}
.fd-rail.dragging .fd-lever {
  box-shadow: 0 9rpx 26rpx rgba(54, 58, 80, 0.28), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}
.fd-lever-bar {
  width: 7rpx; /* 设计 4px */
  height: 34rpx; /* 设计 18px */
  border-radius: 4rpx;
  background: linear-gradient(180deg, #dad8d0, #e9e7e0);
  box-shadow: inset 0 2rpx 2rpx rgba(0, 0, 0, 0.1), 0 2rpx 0 rgba(255, 255, 255, 0.85);
}
.fd-hint {
  margin-top: 11rpx;
  text-align: center;
  font-size: 22rpx; /* 设计 12px */
  color: var(--ld-content-2);
}

/* ---------- 真机走查要点卡 ---------- */
.fd-check {
  margin-top: 48rpx;
  padding: 26rpx 30rpx;
  border: 1rpx solid var(--ld-line);
  border-radius: var(--ld-radius-md);
  background: var(--ld-bg-faint);
}
.fd-check-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ld-ink);
  margin-bottom: 12rpx;
}
.fd-check-item {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--ld-content);
}
.fd-check-note {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--ld-content-2);
}
