<!-- 编辑收货地址·重设计对齐 Checkout.jsx AddressEdit + checkout.css coaddr-* 版式（设计 402px→rpx ×1.87）。
     业务逻辑不动：字段绑定(value/data-field/bind:input)/默认开关(onToggleDefault)/保存(onSave) 一字未改；
     顶部标题走原生导航栏（navigationBarTitleText），故不渲染设计的 co-header/co-nav。
     所在地区＝微信内置 <picker mode="region"> 省市区级联（全国数据运行时自带·region 空格拼接为真相源·守卫 rw-mp-address-region-picker）。 -->
<view class="coaddr">
  <view class="co-body">

    <!-- 表单卡（收货人 / 手机号 / 所在地区 / 详细地址·同卡内发丝线分隔） -->
    <view class="co-card coaddr-form">
      <view class="coaddr-field">
        <text class="coaddr-label">收货人</text>
        <input class="coaddr-input" value="{{name}}" data-field="name" bind:input="onInput"
          placeholder="请填写收货人姓名" placeholder-class="coaddr-ph" />
      </view>
      <view class="coaddr-field">
        <text class="coaddr-label">手机号</text>
        <input class="coaddr-input" value="{{phone}}" data-field="phone" bind:input="onInput" type="number"
          placeholder="请填写手机号" placeholder-class="coaddr-ph" />
      </view>
      <view class="coaddr-field">
        <text class="coaddr-label">所在地区</text>
        <picker class="coaddr-picker" mode="region" value="{{regionArr}}" bind:change="onRegionChange">
          <view class="coaddr-input {{region ? '' : 'coaddr-ph'}}">{{region || '省 / 市 / 区'}}</view>
        </picker>
      </view>
      <view class="coaddr-field">
        <text class="coaddr-label">详细地址</text>
        <input class="coaddr-input" value="{{detail}}" data-field="detail" bind:input="onInput"
          placeholder="街道、楼牌号、门牌号等" placeholder-class="coaddr-ph" />
      </view>
    </view>

    <!-- 设为默认（通用开关·点整卡切换） -->
    <view class="co-card coaddr-default {{isDefault ? 'on' : ''}}" bind:tap="onToggleDefault">
      <text class="coaddr-default-text">设为默认地址</text>
      <view class="co-switch">
        <view class="co-switch-dot"></view>
      </view>
    </view>

    <!-- 删除（仅编辑既有地址时出现） -->
    <view class="co-card coaddr-delete" wx:if="{{id}}" bind:tap="onDelete">
      <image class="coaddr-delete-ico" src="/static/icons/trash-2.svg" mode="aspectFit" />
      <text>删除收货地址</text>
    </view>

  </view>

  <!-- 底部保存坞 -->
  <view class="co-dock-space"></view>
  <view class="co-dock">
    <view class="co-dockbar coaddr-dock">
      <view class="co-submit coaddr-save {{valid ? '' : 'dim'}}" bind:tap="onSave">保存</view>
    </view>
  </view>
</view>
