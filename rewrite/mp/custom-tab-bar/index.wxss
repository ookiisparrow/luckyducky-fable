/* 悬浮胶囊 TabBar（2026-07-16 用户需求：由 2026-07-13 贴边通栏改回悬浮形态）。
   守住 2026-07-13「tabbar 不要透明」的约束——悬浮≠透明：胶囊本体实底不透明（白底），四周
   加显著投影使其读作「浮在内容之上的一块实心胶囊」而非透明空洞（当初透明感来自露内容+安全区悬空，
   靠实底+重投影+胶囊分明的形体消解）。官方 custom-tab-bar 机制不变（setActive/角标/switchTab 在 index.ts）；此文件只管视觉。 */
.ld-tabbar {
  position: fixed;
  left: 44rpx;
  right: 44rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 8rpx;
  padding: 12rpx;
  background: var(--ld-bg, #ffffff);
  /* 胶囊：整体大圆角药丸 */
  border-radius: var(--ld-radius-pill, 999rpx);
  /* 实底不透明 + 显著落影：读作浮起的实心块，非透明空洞（守 2026-07-13「不要透明」） */
  box-shadow: 0 12rpx 40rpx rgba(28, 28, 32, 0.2), 0 4rpx 12rpx rgba(28, 28, 32, 0.1);
}
.ld-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
  /* 内部选中态也走胶囊形，与外壳呼应 */
  border-radius: var(--ld-radius-pill, 999rpx);
}
.ld-tab-iconwrap {
  position: relative;
}
.ld-tab-icon {
  width: 38rpx;
  height: 38rpx;
  display: block;
}
.ld-tab-badge {
  position: absolute;
  top: -12rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: var(--ld-radius-pill, 999rpx);
  background: var(--ld-purple, #a371ea);
  color: #ffffff;
  font-size: 18rpx;
}
.ld-tab-label {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.55);
}
.ld-tab.active {
  background: #f2ebfc; /* 选中丁香紫药丸（设计 #F2EBFC） */
}
.ld-tab.active .ld-tab-label {
  color: var(--ld-purple-tab, #7b5caf);
  font-weight: 600;
}
