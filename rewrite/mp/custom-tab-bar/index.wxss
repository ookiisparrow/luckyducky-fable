/* 全宽圆角悬浮 TabBar（重设计·Chrome.jsx/首页.html：白底圆角条·三等分 tab·图标+文字横排·选中丁香紫药丸）。
   官方 custom-tab-bar 机制不变（setActive/角标/switchTab 在 index.ts）；此文件只管视觉。 */
.ld-tabbar {
  position: fixed;
  left: 52rpx;
  right: 52rpx;
  bottom: calc(15rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 8rpx;
  padding: 15rpx;
  background: var(--ld-bg);
  border-radius: 52rpx;
  box-shadow: 0 15rpx 56rpx rgba(28, 28, 32, 0.22), 0 4rpx 15rpx rgba(28, 28, 32, 0.12);
}
.ld-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
  border-radius: 37rpx;
}
.ld-tab-iconwrap {
  position: relative;
}
.ld-tab-icon {
  width: 38rpx;
  height: 38rpx;
  display: block;
}
.ld-tab-badge {
  position: absolute;
  top: -12rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: var(--ld-radius-pill);
  background: var(--ld-purple);
  color: #ffffff;
  font-size: 18rpx;
}
.ld-tab-label {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.55);
}
.ld-tab.active {
  background: #f2ebfc; /* 选中丁香紫药丸（设计 #F2EBFC） */
}
.ld-tab.active .ld-tab-label {
  color: var(--ld-purple-tab);
  font-weight: 600;
}
