---
// 基础布局：meta/canonical/分享卡/组织+站点卡全站注入（GEO 基建）。
// og:type 按页分流（默认 website·教程页传 article）；noindex 供 404 等不该进索引的页；
// og:image 缺省用品牌分享图 /og-cover.png（真实存在，守卫 rw-site-in-gates 核）。
import { orgSchema, websiteSchema, jsonLd, BRAND_NAME } from '../lib/schema'

interface Props {
  title: string
  description: string
  type?: 'website' | 'article'
  noindex?: boolean
  image?: string
  publishedTime?: string
  modifiedTime?: string
}
const { title, description, type = 'website', noindex = false, image, publishedTime, modifiedTime } = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImage = new URL(image || '/og-cover.png', Astro.site)
const fullTitle = `${title} · ${BRAND_NAME}`
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title={`${BRAND_NAME} · 钩织教程`} href="/rss.xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={BRAND_NAME} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={jsonLd(orgSchema())} />
    <script type="application/ld+json" set:html={jsonLd(websiteSchema())} />
  </head>
  <body>
    <header>
      <a href="/" class="brand">🦆 {BRAND_NAME}</a>
      <nav>
        <a href="/tutorials/">钩织教程</a>
        <a href="/kits/">材料包</a>
        <a href="/about/">关于</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <p>{BRAND_NAME} · 学习钩织，创造幸运。</p>
      <p class="mp-hint">材料包购买与视频课程在微信小程序内：微信搜「LuckyDucky小棉鸭」</p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
    color: #222;
    background: #fcfaff;
    line-height: 1.7;
  }
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    background: #fff;
    border-bottom: 1px solid #c9bbe0;
  }
  .brand {
    font-weight: 700;
    color: #241733;
    text-decoration: none;
  }
  nav a {
    color: #7b5caf;
    text-decoration: none;
    margin-left: 16px;
  }
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 20px 64px;
  }
  footer {
    text-align: center;
    padding: 32px 20px;
    font-size: 13px;
    color: #7e6e96;
    border-top: 1px solid #c9bbe0;
    background: #fff;
  }
  .mp-hint {
    color: #7b5caf;
  }
</style>
