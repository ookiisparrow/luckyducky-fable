---
// 基础布局：meta/canonical/组织卡全站注入（GEO 基建）。
import { orgSchema, BRAND_NAME } from '../lib/schema'

interface Props {
  title: string
  description: string
}
const { title, description } = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · {BRAND_NAME}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={`${title} · ${BRAND_NAME}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={BRAND_NAME} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema())} />
  </head>
  <body>
    <header>
      <a href="/" class="brand">🦆 {BRAND_NAME}</a>
      <nav>
        <a href="/tutorials/">钩织教程</a>
        <a href="/kits/">材料包</a>
        <a href="/about/">关于</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <p>{BRAND_NAME} · 学习钩织，创造幸运。</p>
      <p class="mp-hint">材料包购买与视频课程在微信小程序内：微信搜「LuckyDucky小棉鸭」</p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
    color: #222;
    background: #fcfaff;
    line-height: 1.7;
  }
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    background: #fff;
    border-bottom: 1px solid #c9bbe0;
  }
  .brand {
    font-weight: 700;
    color: #241733;
    text-decoration: none;
  }
  nav a {
    color: #7b5caf;
    text-decoration: none;
    margin-left: 16px;
  }
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 20px 64px;
  }
  footer {
    text-align: center;
    padding: 32px 20px;
    font-size: 13px;
    color: #7e6e96;
    border-top: 1px solid #c9bbe0;
    background: #fff;
  }
  .mp-hint {
    color: #7b5caf;
  }
</style>
