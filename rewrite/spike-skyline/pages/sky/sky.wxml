<view class="page">
  <view class="nav" style="padding-top:{{statusBarH}}px">
    <view class="nav-back" bind:tap="goBack">‹ 返回</view>
    <view class="nav-title">{{label}}</view>
    <view class="nav-badge">{{renderer}}</view>
  </view>

  <scroll-view class="body" style="top:{{statusBarH + 44}}px" type="list" scroll-y>
    <include src="../common/tests.wxml" />

    <view class="card">
      <view class="card-h">T5 · 吸顶（Skyline 原生 sticky-header）</view>
      <view class="card-tip">往下滚：黄色条到达顶栏下方时应吸住不动，其区段滚完才被顶走</view>
    </view>
    <sticky-section>
      <sticky-header>
        <view class="sticky-bar">T5 吸顶条（sticky-header）</view>
      </sticky-header>
      <view class="row" wx:for="{{items}}" wx:key="id">{{item.text}}</view>
    </sticky-section>
    <view class="end-pad"></view>
  </scroll-view>

  <view class="mask" wx:if="{{maskOpen}}" catch:touchmove="noop">
    <view class="mask-t">
      <view>在这层遮罩上来回滑动</view>
      <view>背景列表跟着滚＝穿透（记 ❌）</view>
      <view>背景纹丝不动＝已锁（记 ✅）</view>
    </view>
    <view class="mask-close" bind:tap="closeMask">关闭遮罩</view>
  </view>

  <view class="tabbar">
    <view class="tab">首页</view>
    <view class="tab">目录</view>
    <view class="tab">我的</view>
  </view>
</view>
