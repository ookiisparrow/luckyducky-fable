.wrap {
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
}
.h1 {
  font-size: 20px;
  font-weight: bold;
  margin-bottom: 12px;
}
.tip {
  color: #666;
  line-height: 1.6;
  margin-bottom: 16px;
}
.tip.small {
  font-size: 12px;
  margin-top: 16px;
}
.env {
  background: #fff;
  border-radius: 12px;
  padding: 12px 14px;
  line-height: 1.9;
  margin-bottom: 20px;
}
.btn {
  height: 46px;
  border-radius: 23px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 16px;
  margin-bottom: 14px;
}
.btn-sky {
  background: #a371ea;
}
.btn-web {
  background: #4a90d9;
}
