{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/guard-deploy.mjs\"",
            "timeout": 10,
            "statusMessage": "部署闸检查"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/check-conventions.mjs\" --hook",
            "timeout": 15,
            "statusMessage": "约定检查（CLAUDE.md §5/§8）"
          }
        ]
      }
    ]
  }
}
