{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(npm run check)",
      "Bash(npm run check:*)",
      "Bash(npm run report)",
      "Bash(npm run report:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(date:*)",
      "Bash(wc:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/guard-deploy.mjs\"",
            "timeout": 10,
            "statusMessage": "部署闸检查"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/check-structure.mjs\" --hook",
            "timeout": 15,
            "statusMessage": "结构不变量检查（重构主张守卫）"
          }
        ]
      }
    ]
  }
}
